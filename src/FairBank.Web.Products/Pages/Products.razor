@page "/produkty"
@namespace FairBank.Web.Products.Pages
@using FairBank.Web.Products.Services
@inject IAuthService Auth

<PageHeader Title="PRODUKTY" />

<div class="page-content">

    <div class="product-tabs">
        <button class="product-tab @(_activeTab == "loan" ? "active" : "")"
                @onclick='() => _activeTab = "loan"'>
            <span class="tab-icon"><VbIcon Name="wallet" Size="sm" /></span> Osobní úvěr
        </button>
        <button class="product-tab @(_activeTab == "mortgage" ? "active" : "")"
                @onclick='() => _activeTab = "mortgage"'>
            <span class="tab-icon"><VbIcon Name="home" Size="sm" /></span> Hypotéka
        </button>
        <button class="product-tab @(_activeTab == "insurance" ? "active" : "")"
                @onclick='() => _activeTab = "insurance"'>
            <span class="tab-icon"><VbIcon Name="shield" Size="sm" /></span> Pojištění
        </button>
        @if (Auth.CurrentSession?.Role is not "Admin" and not "Banker")
        {
            <button class="product-tab @(_activeTab == "my" ? "active" : "")"
                    @onclick='() => _activeTab = "my"'>
                <span class="tab-icon"><VbIcon Name="clipboard" Size="sm" /></span> Moje produkty
            </button>
        }
    </div>

    @switch (_activeTab)
    {
        case "loan":
            <LoanCalculatorPanel />
            break;
        case "mortgage":
            <MortgageCalculatorPanel />
            break;
        case "insurance":
            <InsurancePanel />
            break;
        case "my":
            <MyProductsPanel />
            break;
    }

</div>

@code {
    private string _activeTab = "loan";
}
