@page "/"
@namespace FairBank.Admin.Web.Components.Pages
@inject IAuthService Auth
@inject NavigationManager Navigation

<PageHeader Title="ADMIN DASHBOARD" ShowChip="false" />

<div class="page-content">
    <ContentCard Title="Správa systému">
        <ChildContent>
            <div class="info-row">
                <span class="info-label">Služba</span>
                <span class="info-value status-active">Admin Portal</span>
            </div>
            <div class="info-row">
                <span class="info-label">Stav</span>
                <span class="info-value status-active">Aktivní</span>
            </div>
            <div class="info-row">
                <span class="info-label">Přihlášený uživatel</span>
                <span class="info-value">@(Auth.CurrentSession?.Email ?? "—")</span>
            </div>
        </ChildContent>
    </ContentCard>

    <ContentCard Title="Logy (Kafka → SQLite)">
        <ChildContent>
            @if (_logs is null)
            {
                <p class="empty-state">Načítání logů…</p>
            }
            else if (_logs.Count == 0)
            {
                <p class="empty-state">Zatím žádné logy.</p>
            }
            else
            {
                <div style="max-height:400px;overflow-y:auto;">
                    @foreach (var log in _logs)
                    {
                        <div class="info-row">
                            <span class="info-label">@log.Timestamp.ToString("HH:mm:ss") [@log.Level]</span>
                            <span class="info-value">@log.Service — @log.Message</span>
                        </div>
                    }
                </div>
            }
        </ChildContent>
    </ContentCard>

    <div class="admin-quick-links">
        <ContentCard Title="Rychlé odkazy">
            <ChildContent>
                <div class="quick-links-grid">
                    <a href="/users" class="quick-link">
                        <VbIcon Name="users" Size="md" />
                        <span>Správa uživatelů</span>
                    </a>
                    <a href="/logs" class="quick-link">
                        <VbIcon Name="clipboard-list" Size="md" />
                        <span>Auditní logy</span>
                    </a>
                </div>
            </ChildContent>
        </ContentCard>
    </div>
</div>

<style>
    .quick-links-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
    }

    .quick-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        padding: 1.25rem;
        background: var(--vb-bg);
        border: 1px solid var(--vb-card-border);
        border-radius: var(--vb-radius-md);
        text-decoration: none;
        color: var(--vb-text-primary);
        font-weight: 600;
        font-size: 0.9rem;
        transition: var(--vb-transition);
    }

    .quick-link:hover {
        border-color: var(--vb-red);
        box-shadow: 0 0 0 2px var(--vb-red-glow);
    }
</style>

@code {
    [Inject] private IDbContextFactory<FairBank.Admin.Web.Data.LogDbContext> DbFactory { get; set; } = default!;

    private List<FairBank.Admin.Web.Data.LogEntry>? _logs;

    protected override async Task OnInitializedAsync()
    {
        var session = Auth.CurrentSession;
        if (session == null) { Navigation.NavigateTo("/login"); return; }
        if (session.Role != "Admin") { Navigation.NavigateTo("/login"); return; }

        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        _logs = await db.Logs
            .OrderByDescending(l => l.Timestamp)
            .Take(50)
            .ToListAsync();
    }
}
