@page "/"
@using FairBank.Admin.Web.Services
@using FairBank.Admin.Web.Data
@using Microsoft.EntityFrameworkCore
@inject KafkaLogConsumerService LogService
@inject IDbContextFactory<LogDbContext> DbFactory
@inject IJSRuntime JS
@attribute [Authorize]
@implements IDisposable

<PageTitle>Admin Dashboard | FairBank</PageTitle>

<div class="premium-container">
    <header class="mb-5 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="text-gradient mb-1">System Intelligence</h1>
            <p class="text-secondary">Centralized Log Analytics & Real-time Monitoring</p>
        </div>
        <div class="d-flex gap-3 align-items-center">
            <div class="glass-card py-2 px-3 d-flex align-items-center gap-2">
                <i data-lucide="activity" class="text-success" style="width: 16px"></i>
                <span class="fs-6 fw-medium">Kafka connected</span>
            </div>
            <a href="/logout" class="btn-premium btn-danger-soft">
                <i data-lucide="log-out" style="width: 16px"></i>
                Logout
            </a>
        </div>
    </header>

    <!-- Filter Bar -->
    <div class="glass-card mb-4">
        <div class="filter-bar">
            <div>
                <label class="form-label text-secondary small fw-bold">SEARCH</label>
                <div class="position-relative">
                    <input type="text" class="form-control-premium ps-5" @bind="SearchText" @bind:event="oninput" placeholder="Keyword, trace id..." />
                    <i data-lucide="search" class="position-absolute translate-middle-y top-50 start-0 ms-3 text-secondary" style="width:18px"></i>
                </div>
            </div>
            <div>
                <label class="form-label text-secondary small fw-bold">LEVEL</label>
                <select class="form-control-premium" @bind="SelectedLevel">
                    <option value="">All Levels</option>
                    <option value="Information">Information</option>
                    <option value="Warning">Warning</option>
                    <option value="Error">Error</option>
                    <option value="Critical">Critical</option>
                </select>
            </div>
            <div>
                <label class="form-label text-secondary small fw-bold">SERVICE</label>
                <select class="form-control-premium" @bind="SelectedService">
                    <option value="">All Services</option>
                    <option value="ApiGateway">ApiGateway</option>
                    <option value="Identity">Identity</option>
                    <option value="Accounts">Accounts</option>
                </select>
            </div>
            <div>
                <button class="btn-premium w-100" @onclick="RefreshLogs">
                    <i data-lucide="refresh-cw"></i>
                    Refresh
                </button>
            </div>
        </div>
    </div>

    <!-- Logs Table -->
    <div class="glass-card p-0 overflow-hidden">
        <div style="max-height: 65vh; overflow-y: auto;">
            <table class="log-table">
                <thead class="sticky-top bg-dark">
                    <tr>
                        <th class="log-cell text-secondary small fw-bold">TIMESTAMP</th>
                        <th class="log-cell text-secondary small fw-bold">SERVICE</th>
                        <th class="log-cell text-secondary small fw-bold">LEVEL</th>
                        <th class="log-cell text-secondary small fw-bold">MESSAGE</th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredLogs.Any())
                    {
                        @foreach (var log in FilteredLogs)
                        {
                            <tr class="log-row">
                                <td class="log-cell text-secondary" style="width: 180px">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td class="log-cell fw-medium" style="width: 120px">@log.Service</td>
                                <td class="log-cell" style="width: 120px">
                                    <span class="badge-level level-@log.Level.ToLower()">@log.Level</span>
                                </td>
                                <td class="log-cell font-monospace">@log.Message</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-secondary">
                                <i data-lucide="search-x" class="mb-3 d-block mx-auto" style="width:48px; height:48px"></i>
                                No logs found matching your criteria.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<LogEntry> FilteredLogs = new();
    private string SearchText = "";
    private string SelectedLevel = "";
    private string SelectedService = "";

    protected override async Task OnInitializedAsync()
    {
        await RefreshLogs();
        LogService.OnLogsUpdated += HandleLiveLogs;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initLucide");
    }

    private async Task RefreshLogs()
    {
        using var db = DbFactory.CreateDbContext();
        var query = db.Logs.AsQueryable();

        if (!string.IsNullOrWhiteSpace(SearchText))
            query = query.Where(l => l.Message.Contains(SearchText));

        if (!string.IsNullOrWhiteSpace(SelectedLevel))
            query = query.Where(l => l.Level == SelectedLevel);

        if (!string.IsNullOrWhiteSpace(SelectedService))
            query = query.Where(l => l.Service == SelectedService);

        FilteredLogs = await query.OrderByDescending(l => l.Timestamp).Take(500).ToListAsync();
        StateHasChanged();
    }

    private void HandleLiveLogs()
    {
        // For simplicity, we just trigger a refresh when new logs arrive if user is on page
        InvokeAsync(async () => {
            await RefreshLogs();
        });
    }

    public void Dispose()
    {
        LogService.OnLogsUpdated -= HandleLiveLogs;
    }
}
