@page "/"
@page "/prehled"
@namespace FairBank.Web.Overview.Pages
@inject IFairBankApi Api
@inject IAuthService Auth

<PageHeader Title="PŘEHLED ÚČTU" ShowChip="false">
    <Actions>
        <button class="btn-icon" title="Notifikace"><VbIcon Name="bell" Size="sm" /></button>
    </Actions>
</PageHeader>

<div class="page-content overview-page">

    @* ── HERO BALANCE CARD ────────────────────── *@
    <BalanceCard Amount="@_balance" Currency="Kč" Variant="hero" Label="ZŮSTATEK" SubText="@_accountNumber">
        <div class="hero-quick-actions">
            <VbButton Variant="outline" Size="sm" IconName="send" OnClick="@(() => Nav("platby"))">Poslat</VbButton>
            <VbButton Variant="outline" Size="sm" IconName="qr" OnClick="@(() => Nav("platby"))">QR</VbButton>
            <VbButton Variant="outline" Size="sm" IconName="arrow-down" OnClick="@(() => Nav("platby"))">Přijmout</VbButton>
        </div>
    </BalanceCard>

    @* ── CHILD ROLE: SPENDING LIMIT & PENDING ─── *@
    @if (_session?.Role == "Child" && _account is not null)
    {
        @if (_account.SpendingLimit is not null)
        {
            <ContentCard Title="MŮJ LIMIT">
                <ChildContent>
                    <div class="limit-info" style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;">
                        <span style="color:var(--vb-text-secondary);">Denní limit:</span>
                        <strong style="color:var(--vb-text-primary);font-size:1.1rem;">
                            @_account.SpendingLimit.Value.ToString("N0") @_account.Currency
                        </strong>
                    </div>
                </ChildContent>
            </ContentCard>
        }

        @if (_pendingCount > 0)
        {
            <ContentCard Title="ČEKAJÍCÍ PLATBY">
                <ChildContent>
                    <div style="color:var(--vb-gold);padding:8px 0;">
                        <strong>@_pendingCount</strong> @(_pendingCount == 1 ? "platba čeká" : "platby čekají") na schválení rodičem
                    </div>
                </ChildContent>
            </ContentCard>
        }
    }

    @* ── CHALLENGES / VÝZVY ───────────────────── *@
    <ContentCard Title="MOJE VÝZVY" CssClass="section-challenges">
        <Icon><VbIcon Name="rocket" Size="sm" Color="var(--vb-red)" /></Icon>
        <HeaderAction><a class="link-action" href="sporeni">Vše</a></HeaderAction>
        <ChildContent>
            @foreach (var challenge in _challenges)
            {
                <div class="challenge-card">
                    <div class="challenge-icon">
                        <VbIcon Name="@challenge.Icon" Size="sm" Color="var(--vb-gold)" />
                    </div>
                    <div class="challenge-info">
                        <span class="challenge-name">@challenge.Name</span>
                        <div class="challenge-progress-row">
                            <div class="progress-bar-track" style="flex:1;margin-top:0">
                                <div class="progress-bar-fill" style="width:@(challenge.ProgressPercent)%"></div>
                            </div>
                            <span class="challenge-percent">@challenge.ProgressPercent%</span>
                        </div>
                    </div>
                </div>
            }
        </ChildContent>
    </ContentCard>

    @* ── RECENT TRANSACTIONS ──────────────────── *@
    <ContentCard Title="NEDÁVNÉ TRANSAKCE">
        <Icon><VbIcon Name="clock" Size="sm" Color="var(--vb-red)" /></Icon>
        <HeaderAction><a class="link-action" href="platby?view=pohyby">Vše</a></HeaderAction>
        <ChildContent>
            @foreach (var tx in _transactions)
            {
                <TransactionItem
                    Description="@tx.Description"
                    Date="@tx.Date"
                    Amount="@tx.Amount"
                    Currency="Kč"
                    Type="@tx.Type"
                    Category="@tx.Category" />
            }

            @if (!_transactions.Any())
            {
                <p class="empty-state">Zatím žádné transakce</p>
            }
        </ChildContent>
    </ContentCard>

    @* ── AUTO SAVINGS ROULETTE ────────────────── *@
    <ContentCard Title="AUTOMATICKÉ SPOŘENÍ" CssClass="section-savings">
        <Icon><VbIcon Name="target" Size="sm" Color="var(--vb-red)" /></Icon>
        <ChildContent>
            <div class="auto-savings-visual">
                <div class="savings-roulette">
                    @foreach (var milestone in _savingsMilestones)
                    {
                        <div class="savings-milestone @(milestone.IsReached ? "reached" : "")">
                            <PokerChip Value="@milestone.Label" IsActive="@milestone.IsReached" Size="sm" />
                            <span class="milestone-amount">@milestone.Amount.ToString("N0") Kč</span>
                        </div>
                    }
                </div>
                <div class="savings-summary">
                    <div class="stat-row">
                        <span class="stat-label">Naspořeno tento měsíc</span>
                        <span class="stat-value positive">+2 340 Kč</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-label">Celkové spoření</span>
                        <span class="stat-value">155 700 Kč</span>
                    </div>
                </div>
            </div>
        </ChildContent>
    </ContentCard>

    @* ── FINANCIAL TIP ────────────────────────── *@
    <div class="tip-card">
        <div class="tip-icon"><VbIcon Name="fire" Size="sm" /></div>
        <div class="tip-content">
            <span class="tip-title">Finanční Tip</span>
            <span class="tip-text">Pravidelné spoření i malých částek vám díky složenému úročení může přinést významné výnosy.</span>
        </div>
    </div>

</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private FairBank.Web.Shared.Models.AuthSession? _session;
    private FairBank.Web.Shared.Models.AccountResponse? _account;
    private decimal _balance = 0m;
    private string _accountNumber = "---";
    private int _pendingCount;
    private List<TransactionVm> _transactions = [];
    private List<ChallengeVm> _challenges = [];
    private List<MilestoneVm> _savingsMilestones = [];

    protected override async Task OnInitializedAsync()
    {
        // Load real account data if available
        try
        {
            _session = Auth.CurrentSession;
            if (_session is { } session)
            {
                var accounts = await Api.GetAccountsByOwnerAsync(session.UserId);
                if (accounts.Any())
                {
                    _account = accounts[0];
                    _balance = accounts.Sum(a => a.Balance);
                    _accountNumber = _account.AccountNumber;

                    // Load real transactions
                    var payments = await Api.GetPaymentsByAccountAsync(_account.Id);
                    _transactions = payments.Select(p => new TransactionVm(
                        p.Description ?? p.RecipientAccountNumber,
                        p.CreatedAt,
                        p.SenderAccountId == _account.Id ? -p.Amount : p.Amount,
                        p.SenderAccountId == _account.Id ? "withdrawal" : "deposit",
                        ""
                    )).Take(5).ToList();

                    // Load pending transaction count for Child role
                    if (_session.Role == "Child")
                    {
                        var pending = await Api.GetPendingTransactionsAsync(_account.Id);
                        _pendingCount = pending.Count;
                    }
                }
            }
        }
        catch { /* Use demo data below */ }

        // Fill with demo data if empty
        if (!_transactions.Any())
        {
            _transactions =
            [
                new("Nákupy", DateTime.Now.AddDays(-1), -2_500m, "withdrawal", "shopping"),
                new("Převod od Jana", DateTime.Now.AddDays(-1), 15_000m, "deposit", "transfer"),
                new("Restaurace", DateTime.Now.AddDays(-2), -890m, "withdrawal", "food"),
                new("Benzín", DateTime.Now.AddDays(-3), -1_200m, "withdrawal", "car"),
                new("Dovolená", DateTime.Now.AddDays(-4), -8_500m, "withdrawal", "travel"),
            ];
        }

        _challenges =
        [
            new("Dovolená", 70, "travel"),
            new("Nouzový fond", 45, "shield"),
            new("Investuj měsíčně", 90, "chart"),
        ];

        _savingsMilestones =
        [
            new("10k", 10_000m, true),
            new("15k", 15_000m, true),
            new("50k", 50_000m, false),
            new("30k", 30_000m, false),
            new("100k", 100_000m, false),
        ];
    }

    private void Nav(string page) => Navigation.NavigateTo(page);

    private sealed record TransactionVm(string Description, DateTime Date, decimal Amount, string Type, string Category);
    private sealed record ChallengeVm(string Name, int ProgressPercent, string Icon);
    private sealed record MilestoneVm(string Label, decimal Amount, bool IsReached);
}
