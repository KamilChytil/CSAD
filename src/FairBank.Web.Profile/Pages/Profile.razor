@page "/profil"
@namespace FairBank.Web.Profile.Pages
@inject IFairBankApi Api
@inject IAuthService Auth
@inject NavigationManager Nav
@inject ThemeService Theme
@implements IDisposable

<PageHeader Title="PROFIL" ShowChip="false" />

<div class="page-content profile-page">

    @* ── PROFILE HERO ─────────────────────────── *@
    <div class="profile-hero">
        <div class="profile-avatar">
            <div class="avatar-chip">
                <PokerChip Value="@_initials" Size="lg" IsActive="true" />
            </div>
        </div>
        <h2 class="profile-name">@_fullName</h2>
        <span class="profile-email">@_email</span>
        <div class="profile-badges">
            <span class="badge badge-blue">@_role</span>
            <span class="badge badge-green">Aktivní</span>
        </div>
    </div>

    @* ── PERSONAL INFO ────────────────────────── *@
    <ContentCard Title="Osobní údaje">
        <Icon><VbIcon Name="user" Size="sm" Color="var(--vb-red)" /></Icon>
        <ChildContent>
            <div class="info-row">
                <span class="info-label">Jméno</span>
                <span class="info-value">@_firstName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Příjmení</span>
                <span class="info-value">@_lastName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Email</span>
                <span class="info-value">
                    @_email
                    @if (!_showChangeEmail)
                    {
                        <button class="inline-link-btn" @onclick="StartEmailChange">Změnit email</button>
                    }
                </span>
            </div>
            @if (_showChangeEmail)
            {
                <div class="inline-edit-form">
                    <div class="form-group">
                        <label class="form-label">Nový email</label>
                        <input class="form-input" type="email" @bind="_newEmail" placeholder="novyemail@example.com" />
                    </div>
                    @if (!string.IsNullOrEmpty(_emailError))
                    {
                        <div class="field-error">@_emailError</div>
                    }
                    @if (!string.IsNullOrEmpty(_emailSuccess))
                    {
                        <div class="save-success">
                            <VbIcon Name="check" Size="xs" Color="var(--vb-green)" /> @_emailSuccess
                        </div>
                    }
                    <div class="form-actions">
                        <VbButton Variant="primary" Size="sm" OnClick="HandleChangeEmail" Disabled="@_emailSaving">
                            @(_emailSaving ? "Ukládám..." : "Uložit")
                        </VbButton>
                        <VbButton Variant="ghost" Size="sm" OnClick="CancelEmailChange">Zrušit</VbButton>
                    </div>
                </div>
            }
            <div class="info-row">
                <span class="info-label">Role</span>
                <span class="info-value">@_role</span>
            </div>
        </ChildContent>
    </ContentCard>

    @* ── SETTINGS ─────────────────────────────── *@
    <ContentCard Title="Nastavení">
        <Icon><VbIcon Name="settings" Size="sm" Color="var(--vb-red)" /></Icon>
        <ChildContent>
            <ToggleSwitch Label="Push notifikace" @bind-IsOn="_pushEnabled" />
            <div class="settings-divider"></div>
            <div class="theme-setting">
                <ToggleSwitch Label="Tmavý režim" IsOn="@Theme.IsDarkMode" IsOnChanged="OnDarkModeToggled" />
                <span class="settings-hint">
                    <VbIcon Name="@(Theme.IsDarkMode ? "moon" : "sun")" Size="xs" />
                    @(Theme.IsDarkMode ? "Tmavý" : "Světlý") režim aktivní
                </span>
            </div>
            <div class="settings-divider"></div>
            <ToggleSwitch Label="Biometrické přihlášení" @bind-IsOn="_biometricEnabled" />
        </ChildContent>
    </ContentCard>

    @* ── ACCOUNT INFO ─────────────────────────── *@
    <ContentCard Title="Účet">
        <Icon><VbIcon Name="wallet" Size="sm" Color="var(--vb-red)" /></Icon>
        <ChildContent>
            <div class="info-row">
                <span class="info-label">Číslo účtu</span>
                <span class="info-value account-number">@_accountNumber</span>
            </div>
            <div class="info-row">
                <span class="info-label">Stav</span>
                <span class="info-value"><span class="badge badge-green">Aktivní</span></span>
            </div>
            <div class="info-row">
                <span class="info-label">Vytvořeno</span>
                <span class="info-value">@_createdAt.ToString("dd.MM.yyyy")</span>
            </div>
        </ChildContent>
    </ContentCard>

    @* ── 2FA SECTION ─────────────────────────── *@
    <ContentCard Title="Dvoufaktorové ověření (2FA)">
        <Icon><VbIcon Name="shield" Size="sm" Color="var(--vb-red)" /></Icon>
        <ChildContent>
            @if (_2faLoading)
            {
                <div class="section-loading">
                    <span class="loading-text">Načítání...</span>
                </div>
            }
            else if (_2faEnabled)
            {
                @* 2FA is enabled — show status and option to disable *@
                <div class="twofa-status">
                    <div class="twofa-status-row">
                        <div class="security-info">
                            <VbIcon Name="check" Size="sm" Color="var(--vb-green)" />
                            <span>Dvoufaktorové ověření je <strong>aktivní</strong></span>
                        </div>
                        <span class="badge badge-green">Zapnuto</span>
                    </div>
                </div>

                @if (_showDisable2fa)
                {
                    <div class="twofa-action-area">
                        <div class="form-group">
                            <label class="form-label">Zadejte kód z autentizační aplikace pro vypnutí</label>
                            <input class="form-input" type="text" maxlength="6" inputmode="numeric"
                                   @bind="_disable2faCode" @bind:event="oninput"
                                   placeholder="000000" />
                        </div>
                        @if (!string.IsNullOrEmpty(_2faError))
                        {
                            <div class="field-error">@_2faError</div>
                        }
                        <div class="form-actions">
                            <VbButton Variant="danger" Size="sm" OnClick="HandleDisable2fa" Disabled="@_2faSaving">
                                @(_2faSaving ? "Vypínání..." : "Vypnout 2FA")
                            </VbButton>
                            <VbButton Variant="ghost" Size="sm" OnClick="@(() => { _showDisable2fa = false; _2faError = ""; })">Zrušit</VbButton>
                        </div>
                    </div>
                }
                else
                {
                    <div class="twofa-action-area">
                        <VbButton Variant="outline" Size="sm" IconName="x-circle" OnClick="@(() => _showDisable2fa = true)">Vypnout 2FA</VbButton>
                    </div>
                }
            }
            else
            {
                @* 2FA is disabled — show enable flow *@
                <div class="twofa-status">
                    <div class="twofa-status-row">
                        <div class="security-info">
                            <VbIcon Name="warning" Size="sm" Color="var(--vb-orange)" />
                            <span>Dvoufaktorové ověření je <strong>vypnuto</strong></span>
                        </div>
                        <span class="badge badge-red">Vypnuto</span>
                    </div>
                </div>

                @if (_2faSetupResponse is not null)
                {
                    @* Setup flow — show OTP URI and verify *@
                    <div class="twofa-setup">
                        <div class="twofa-setup-instructions">
                            <p class="setup-step">1. Otevřete svou autentizační aplikaci (Google Authenticator, Authy apod.)</p>
                            <p class="setup-step">2. Přidejte nový účet pomocí tajného klíče níže:</p>
                        </div>

                        <div class="twofa-secret-box">
                            <span class="secret-label">Tajný klíč</span>
                            <code class="secret-value">@_2faSetupResponse.Secret</code>
                        </div>

                        <div class="twofa-uri-box">
                            <span class="secret-label">OTP URI (pro ruční zadání)</span>
                            <code class="secret-value uri-value">@_2faSetupResponse.OtpAuthUri</code>
                        </div>

                        <div class="form-group">
                            <label class="form-label">3. Zadejte ověřovací kód z aplikace</label>
                            <input class="form-input" type="text" maxlength="6" inputmode="numeric"
                                   @bind="_enable2faCode" @bind:event="oninput"
                                   placeholder="000000" />
                        </div>

                        @if (!string.IsNullOrEmpty(_2faError))
                        {
                            <div class="field-error">@_2faError</div>
                        }

                        <div class="form-actions">
                            <VbButton Variant="primary" Size="sm" OnClick="HandleEnable2fa" Disabled="@_2faSaving">
                                @(_2faSaving ? "Ověřování..." : "Ověřit a zapnout")
                            </VbButton>
                            <VbButton Variant="ghost" Size="sm" OnClick="@(() => { _2faSetupResponse = null; _2faError = ""; })">Zrušit</VbButton>
                        </div>
                    </div>
                }
                else if (_backupCodes is not null)
                {
                    @* Show backup codes after successful enable *@
                    <div class="twofa-backup-codes">
                        <div class="backup-warning">
                            <VbIcon Name="warning" Size="sm" Color="var(--vb-orange)" />
                            <span><strong>Uložte si záložní kódy!</strong> Tyto kódy se zobrazí pouze jednou. Uložte je na bezpečné místo.</span>
                        </div>
                        <div class="backup-codes-grid">
                            @foreach (var backupCode in _backupCodes)
                            {
                                <code class="backup-code">@backupCode</code>
                            }
                        </div>
                        <VbButton Variant="primary" Size="sm" OnClick="@(() => _backupCodes = null)">Hotovo, kódy jsem si uložil/a</VbButton>
                    </div>
                }
                else
                {
                    <div class="twofa-action-area">
                        <VbButton Variant="primary" Size="sm" IconName="shield" OnClick="HandleSetup2fa" Disabled="@_2faSaving">
                            @(_2faSaving ? "Příprava..." : "Zapnout 2FA")
                        </VbButton>
                    </div>
                }
            }
        </ChildContent>
    </ContentCard>

    @* ── DEVICES SECTION ─────────────────────── *@
    <ContentCard Title="Přihlášená zařízení">
        <Icon><VbIcon Name="lock" Size="sm" Color="var(--vb-red)" /></Icon>
        <ChildContent>
            @if (_devicesLoading)
            {
                <div class="section-loading">
                    <span class="loading-text">Načítání zařízení...</span>
                </div>
            }
            else if (!_devices.Any())
            {
                <div class="section-empty">
                    <span class="empty-text">Žádná zařízení</span>
                </div>
            }
            else
            {
                @foreach (var device in _devices)
                {
                    <div class="device-item @(device.IsCurrentDevice ? "device-current" : "")">
                        <div class="device-info">
                            <div class="device-header">
                                <span class="device-name">
                                    @device.DeviceName
                                    @if (device.IsCurrentDevice)
                                    {
                                        <span class="badge badge-green badge-sm">Toto zařízení</span>
                                    }
                                </span>
                                @if (device.IsTrusted)
                                {
                                    <span class="badge badge-gold badge-sm">Důvěryhodné</span>
                                }
                            </div>
                            <div class="device-details">
                                @if (!string.IsNullOrEmpty(device.Browser))
                                {
                                    <span class="device-detail">@device.Browser</span>
                                }
                                @if (!string.IsNullOrEmpty(device.OperatingSystem))
                                {
                                    <span class="device-detail">@device.OperatingSystem</span>
                                }
                                @if (!string.IsNullOrEmpty(device.IpAddress))
                                {
                                    <span class="device-detail">@device.IpAddress</span>
                                }
                            </div>
                            <span class="device-last-active">Aktivní: @device.LastActiveAt.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <div class="device-actions">
                            @if (!device.IsCurrentDevice)
                            {
                                @if (_confirmRevokeDeviceId == device.Id)
                                {
                                    <div class="device-confirm">
                                        <span class="device-confirm-text">Opravdu odhlásit?</span>
                                        <VbButton Variant="danger" Size="sm" OnClick="@(() => HandleRevokeDevice(device.Id))" Disabled="@_deviceActionLoading">Ano</VbButton>
                                        <VbButton Variant="ghost" Size="sm" OnClick="@(() => _confirmRevokeDeviceId = null)">Ne</VbButton>
                                    </div>
                                }
                                else
                                {
                                    <VbButton Variant="ghost" Size="sm" OnClick="@(() => HandleTrustDevice(device))" Disabled="@_deviceActionLoading">
                                        @(device.IsTrusted ? "Nedůvěřovat" : "Důvěřovat")
                                    </VbButton>
                                    <VbButton Variant="outline" Size="sm" IconName="logout" OnClick="@(() => _confirmRevokeDeviceId = device.Id)">Odhlásit</VbButton>
                                }
                            }
                        </div>
                    </div>
                }
            }
        </ChildContent>
    </ContentCard>

    @* ── SECURITY SETTINGS ───────────────────── *@
    <ContentCard Title="Zabezpečení">
        <Icon><VbIcon Name="shield" Size="sm" Color="var(--vb-red)" /></Icon>
        <ChildContent>
            <div class="security-item">
                <div class="security-info">
                    <VbIcon Name="shield" Size="sm" Color="@(_2faEnabled ? "var(--vb-green)" : "var(--vb-orange)")" />
                    <span>Dvoufaktorové ověření</span>
                </div>
                <span class="badge @(_2faEnabled ? "badge-green" : "badge-red")">@(_2faEnabled ? "Aktivní" : "Vypnuto")</span>
            </div>
            <div class="security-item">
                <div class="security-info">
                    <VbIcon Name="clock" Size="sm" />
                    <span>Poslední přihlášení</span>
                </div>
                <span class="info-value">Dnes</span>
            </div>
            <div class="settings-divider"></div>
            <ToggleSwitch Label="Noční transakce (23:00–06:00)" @bind-IsOn="_nightTransactionsEnabled" />
            <div class="settings-divider"></div>
            <ToggleSwitch Label="Mezinárodní platby" @bind-IsOn="_internationalPaymentsEnabled" />
            <div class="settings-divider"></div>

            @* ── Change Password ── *@
            @if (_showChangePassword)
            {
                <div class="password-change-form">
                    <div class="form-group">
                        <label class="form-label">Současné heslo</label>
                        <input class="form-input" type="password" @bind="_currentPassword" placeholder="Zadejte současné heslo" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Nové heslo</label>
                        <input class="form-input" type="password" @bind="_newPassword" @bind:event="oninput" placeholder="Zadejte nové heslo" />
                        @if (!string.IsNullOrEmpty(_newPassword))
                        {
                            <div class="password-requirements">
                                <span class="pwd-req @(_newPassword.Length >= 8 ? "pwd-ok" : "pwd-fail")">
                                    @(_newPassword.Length >= 8 ? "\u2713" : "\u2717") Minimálně 8 znaků
                                </span>
                                <span class="pwd-req @(_newPassword.Any(char.IsUpper) ? "pwd-ok" : "pwd-fail")">
                                    @(_newPassword.Any(char.IsUpper) ? "\u2713" : "\u2717") Velké písmeno
                                </span>
                                <span class="pwd-req @(_newPassword.Any(char.IsLower) ? "pwd-ok" : "pwd-fail")">
                                    @(_newPassword.Any(char.IsLower) ? "\u2713" : "\u2717") Malé písmeno
                                </span>
                                <span class="pwd-req @(_newPassword.Any(char.IsDigit) ? "pwd-ok" : "pwd-fail")">
                                    @(_newPassword.Any(char.IsDigit) ? "\u2713" : "\u2717") Číslice
                                </span>
                                <span class="pwd-req @(_newPassword.Any(c => !char.IsLetterOrDigit(c)) ? "pwd-ok" : "pwd-fail")">
                                    @(_newPassword.Any(c => !char.IsLetterOrDigit(c)) ? "\u2713" : "\u2717") Speciální znak
                                </span>
                            </div>
                        }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Potvrzení nového hesla</label>
                        <input class="form-input" type="password" @bind="_confirmPassword" placeholder="Zopakujte nové heslo" />
                    </div>
                    @if (!string.IsNullOrEmpty(_passwordError))
                    {
                        <div class="field-error">@_passwordError</div>
                    }
                    @if (!string.IsNullOrEmpty(_passwordSuccess))
                    {
                        <div class="save-success">
                            <VbIcon Name="check" Size="xs" Color="var(--vb-green)" /> @_passwordSuccess
                        </div>
                    }
                    <div class="form-actions">
                        <VbButton Variant="primary" Size="sm" OnClick="HandleChangePassword" Disabled="@_passwordSaving">
                            @(_passwordSaving ? "Měním heslo..." : "Změnit heslo")
                        </VbButton>
                        <VbButton Variant="ghost" Size="sm" OnClick="CancelPasswordChange">Zrušit</VbButton>
                    </div>
                </div>
            }
            else
            {
                <VbButton Variant="outline" Size="sm" IconName="lock" OnClick="@(() => _showChangePassword = true)">Změnit heslo</VbButton>
            }
        </ChildContent>
    </ContentCard>

    @* ── NOTIFICATION PREFERENCES ────────────── *@
    <ContentCard Title="Notifikace">
        <Icon><VbIcon Name="bell" Size="sm" Color="var(--vb-red)" /></Icon>
        <ChildContent>
            @if (_notifPrefsLoading)
            {
                <div class="section-loading">
                    <span class="loading-text">Načítání předvoleb...</span>
                </div>
            }
            else if (_notifPrefs is not null)
            {
                <ToggleSwitch Label="Transakční notifikace" IsOn="@_notifPrefs.TransactionNotifications"
                              IsOnChanged="@(v => UpdateNotifPref(p => p.TransactionNotifications = v))" />
                <div class="settings-divider"></div>
                <ToggleSwitch Label="Bezpečnostní notifikace" IsOn="@_notifPrefs.SecurityNotifications"
                              IsOnChanged="@(v => UpdateNotifPref(p => p.SecurityNotifications = v))" />
                <div class="settings-divider"></div>
                <ToggleSwitch Label="Notifikace o kartách" IsOn="@_notifPrefs.CardNotifications"
                              IsOnChanged="@(v => UpdateNotifPref(p => p.CardNotifications = v))" />
                <div class="settings-divider"></div>
                <ToggleSwitch Label="Notifikace o limitech" IsOn="@_notifPrefs.LimitNotifications"
                              IsOnChanged="@(v => UpdateNotifPref(p => p.LimitNotifications = v))" />
                <div class="settings-divider"></div>
                <ToggleSwitch Label="Chatové notifikace" IsOn="@_notifPrefs.ChatNotifications"
                              IsOnChanged="@(v => UpdateNotifPref(p => p.ChatNotifications = v))" />
                <div class="settings-divider"></div>
                <ToggleSwitch Label="E-mailové notifikace" IsOn="@_notifPrefs.EmailNotificationsEnabled"
                              IsOnChanged="@(v => UpdateNotifPref(p => p.EmailNotificationsEnabled = v))" />

                @if (!string.IsNullOrEmpty(_notifPrefsSaveError))
                {
                    <div class="field-error" style="margin-top:8px">@_notifPrefsSaveError</div>
                }
                @if (_notifPrefsSaved)
                {
                    <div class="save-success" style="margin-top:8px">
                        <VbIcon Name="check" Size="xs" Color="var(--vb-green)" /> Uloženo
                    </div>
                }
            }
            else
            {
                <div class="section-empty">
                    <span class="empty-text">Předvolby nejsou dostupné</span>
                </div>
            }
        </ChildContent>
    </ContentCard>

    @* ── LOGOUT ───────────────────────────────── *@
    <VbButton Variant="danger" FullWidth="true" IconName="logout" OnClick="HandleLogout">Odhlásit se</VbButton>
</div>

<style>
    /* ── 2FA Section ── */
    .twofa-status-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
    }

    .twofa-action-area {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--vb-divider);
    }

    .twofa-setup {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--vb-divider);
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .twofa-setup-instructions {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .setup-step {
        font-size: 0.85rem;
        color: var(--vb-text-secondary);
        margin: 0;
    }

    .twofa-secret-box,
    .twofa-uri-box {
        background: var(--vb-input-bg);
        border: 1px solid var(--vb-input-border);
        border-radius: var(--vb-radius-sm);
        padding: 10px 14px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .secret-label {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--vb-text-muted);
    }

    .secret-value {
        font-family: 'Courier New', 'Consolas', monospace;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--vb-text-primary);
        word-break: break-all;
        background: none;
        padding: 0;
    }

    .uri-value {
        font-size: 0.75rem;
        font-weight: 400;
    }

    /* ── Backup codes ── */
    .twofa-backup-codes {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--vb-divider);
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .backup-warning {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 10px 14px;
        background: rgba(230, 126, 34, 0.08);
        border: 1px solid rgba(230, 126, 34, 0.2);
        border-radius: var(--vb-radius-sm);
        font-size: 0.85rem;
        color: var(--vb-text-primary);
    }

    .backup-codes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 8px;
    }

    .backup-code {
        font-family: 'Courier New', 'Consolas', monospace;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 8px 12px;
        text-align: center;
        background: var(--vb-input-bg);
        border: 1px solid var(--vb-input-border);
        border-radius: var(--vb-radius-xs);
        color: var(--vb-text-primary);
    }

    /* ── Devices Section ── */
    .device-item {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 12px 0;
        border-bottom: 1px solid var(--vb-divider);
        gap: 12px;
    }

    .device-item:last-child {
        border-bottom: none;
    }

    .device-current {
        background: rgba(39, 174, 96, 0.04);
        border-radius: var(--vb-radius-sm);
        padding: 12px;
        margin: 0 -12px;
    }

    .device-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
        min-width: 0;
    }

    .device-header {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .device-name {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--vb-text-primary);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .badge-sm {
        font-size: 0.65rem;
        padding: 1px 6px;
    }

    .device-details {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .device-detail {
        font-size: 0.8rem;
        color: var(--vb-text-muted);
    }

    .device-last-active {
        font-size: 0.75rem;
        color: var(--vb-text-muted);
    }

    .device-actions {
        display: flex;
        gap: 6px;
        align-items: center;
        flex-shrink: 0;
    }

    .device-confirm {
        display: flex;
