@code {
    private string _firstName = "";
    private string _lastName = "";
    private string _email = "";
    private string _role = "";
    private string _accountNumber = "---";
    private DateTime _createdAt = DateTime.UtcNow;

    private bool _pushEnabled = true;
    private bool _biometricEnabled;

    private string _fullName => $"{_firstName} {_lastName}";
    private string _initials => string.IsNullOrEmpty(_firstName) || string.IsNullOrEmpty(_lastName)
        ? "VB"
        : $"{_firstName[0]}{_lastName[0]}";

    // ── 2FA state ──
    private bool _2faLoading = true;
    private bool _2faEnabled;
    private bool _2faSaving;
    private string _2faError = "";
    private TwoFactorSetupResponse? _2faSetupResponse;
    private string _enable2faCode = "";
    private bool _showDisable2fa;
    private string _disable2faCode = "";
    private string[]? _backupCodes;

    // ── Devices state ──
    private bool _devicesLoading = true;
    private bool _deviceActionLoading;
    private List<DeviceDto> _devices = [];
    private Guid? _confirmRevokeDeviceId;

    // ── Security settings ──
    private bool _nightTransactionsEnabled;
    private bool _internationalPaymentsEnabled;

    // ── Email change ──
    private bool _showChangeEmail;
    private string _newEmail = "";
    private string _emailError = "";
    private string _emailSuccess = "";
    private bool _emailSaving;

    // ── Password change ──
    private bool _showChangePassword;
    private string _currentPassword = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
    private string _passwordError = "";
    private string _passwordSuccess = "";
    private bool _passwordSaving;

    // ── Notification preferences ──
    private bool _notifPrefsLoading = true;
    private NotificationPreferenceDto? _notifPrefs;
    private string _notifPrefsSaveError = "";
    private bool _notifPrefsSaved;

    protected override async Task OnInitializedAsync()
    {
        Theme.OnThemeChanged += HandleThemeChanged;

        if (Auth.CurrentSession is { } session)
        {
            _firstName = session.FirstName;
            _lastName = session.LastName;
            _email = session.Email;
            _role = session.Role;
        }

        // Load account number
        try
        {
            if (Auth.CurrentSession is { } s)
            {
                var accounts = await Api.GetAccountsByOwnerAsync(s.UserId);
                if (accounts.Any())
                {
                    _accountNumber = accounts[0].AccountNumber;
                    _createdAt = accounts[0].CreatedAt;
                }
            }
        }
        catch { /* Use default */ }

        // Load 2FA status, devices, and notification preferences in parallel
        if (Auth.CurrentSession is { } sess)
        {
            var userId = sess.UserId;

            var tasks = new List<Task>
            {
                Load2faStatusAsync(userId),
                LoadDevicesAsync(userId),
                LoadNotificationPreferencesAsync(userId)
            };

            await Task.WhenAll(tasks);
        }
        else
        {
            _2faLoading = false;
            _devicesLoading = false;
            _notifPrefsLoading = false;
        }
    }

    private async Task Load2faStatusAsync(Guid userId)
    {
        try
        {
            var setup = await Api.SetupTwoFactorAsync(userId);
            _2faEnabled = setup?.IsAlreadyEnabled ?? false;
        }
        catch { /* assume disabled */ }
        finally { _2faLoading = false; }
    }

    private async Task LoadDevicesAsync(Guid userId)
    {
        try
        {
            _devices = await Api.GetDevicesAsync(userId);
        }
        catch { _devices = []; }
        finally { _devicesLoading = false; }
    }

    private async Task LoadNotificationPreferencesAsync(Guid userId)
    {
        try
        {
            _notifPrefs = await Api.GetNotificationPreferencesAsync(userId);
            _notifPrefs ??= new NotificationPreferenceDto();
        }
        catch { _notifPrefs = new NotificationPreferenceDto(); }
        finally { _notifPrefsLoading = false; }
    }

    // ── 2FA handlers ──

    private async Task HandleSetup2fa()
    {
        if (Auth.CurrentSession is null) return;
        _2faSaving = true;
        _2faError = "";
        try
        {
            _2faSetupResponse = await Api.SetupTwoFactorAsync(Auth.CurrentSession.UserId);
            if (_2faSetupResponse?.IsAlreadyEnabled == true)
            {
                _2faEnabled = true;
                _2faSetupResponse = null;
            }
        }
        catch
        {
            _2faError = "Chyba při přípravě 2FA. Zkuste to znovu.";
        }
        finally { _2faSaving = false; }
    }

    private async Task HandleEnable2fa()
    {
        if (Auth.CurrentSession is null || string.IsNullOrWhiteSpace(_enable2faCode)) return;
        _2faSaving = true;
        _2faError = "";
        try
        {
            var codes = await Api.EnableTwoFactorAsync(Auth.CurrentSession.UserId, _enable2faCode.Trim());
            if (codes is not null)
            {
                _backupCodes = codes;
                _2faEnabled = true;
                _2faSetupResponse = null;
                _enable2faCode = "";
            }
            else
            {
                _2faError = "Neplatný kód. Zkuste to znovu.";
            }
        }
        catch
        {
            _2faError = "Chyba při aktivaci 2FA. Zkuste to znovu.";
        }
        finally { _2faSaving = false; }
    }

    private async Task HandleDisable2fa()
    {
        if (Auth.CurrentSession is null || string.IsNullOrWhiteSpace(_disable2faCode)) return;
        _2faSaving = true;
        _2faError = "";
        try
        {
            await Api.DisableTwoFactorAsync(Auth.CurrentSession.UserId, _disable2faCode.Trim());
            _2faEnabled = false;
            _showDisable2fa = false;
            _disable2faCode = "";
        }
        catch
        {
            _2faError = "Neplatný kód nebo chyba. Zkuste to znovu.";
        }
        finally { _2faSaving = false; }
    }

    // ── Device handlers ──

    private async Task HandleRevokeDevice(Guid deviceId)
    {
        _deviceActionLoading = true;
        try
        {
            await Api.RevokeDeviceAsync(deviceId);
            _confirmRevokeDeviceId = null;
            if (Auth.CurrentSession is { } s)
                await LoadDevicesAsync(s.UserId);
        }
        catch { /* ignore */ }
        finally
        {
            _deviceActionLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleTrustDevice(DeviceDto device)
    {
        _deviceActionLoading = true;
        try
        {
            await Api.TrustDeviceAsync(device.Id);
            if (Auth.CurrentSession is { } s)
                await LoadDevicesAsync(s.UserId);
        }
        catch { /* ignore */ }
        finally
        {
            _deviceActionLoading = false;
            StateHasChanged();
        }
    }

    // ── Email change handlers ──

    private void StartEmailChange()
    {
        _showChangeEmail = true;
        _newEmail = _email;
        _emailError = "";
        _emailSuccess = "";
    }

    private void CancelEmailChange()
    {
        _showChangeEmail = false;
        _emailError = "";
        _emailSuccess = "";
    }

    private async Task HandleChangeEmail()
    {
        if (Auth.CurrentSession is null) return;

        _emailError = "";
        _emailSuccess = "";

        if (string.IsNullOrWhiteSpace(_newEmail) || !_newEmail.Contains('@'))
        {
            _emailError = "Zadejte platnou e-mailovou adresu.";
            return;
        }

        if (_newEmail.Trim() == _email)
        {
            _emailError = "Nový email je stejný jako současný.";
            return;
        }

        _emailSaving = true;
        try
        {
            await Api.ChangeEmailAsync(Auth.CurrentSession.UserId, _newEmail.Trim());
            _email = _newEmail.Trim();
            _emailSuccess = "Email byl úspěšně změněn.";
            _showChangeEmail = false;

            // Re-login to refresh the session with new email
            try
            {
                await Auth.InitializeAsync();
            }
            catch { /* Session will be refreshed on next load */ }
        }
        catch (Exception ex)
        {
            _emailError = $"Chyba při změně emailu: {ex.Message}";
        }
        finally
        {
            _emailSaving = false;
        }
    }

    // ── Password change handlers ──

    private void CancelPasswordChange()
    {
        _showChangePassword = false;
        _passwordError = "";
        _passwordSuccess = "";
        _currentPassword = "";
        _newPassword = "";
        _confirmPassword = "";
    }

    private async Task HandleChangePassword()
    {
        if (Auth.CurrentSession is null) return;

        _passwordError = "";
        _passwordSuccess = "";

        if (string.IsNullOrWhiteSpace(_currentPassword))
        {
            _passwordError = "Zadejte současné heslo.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            _passwordError = "Zadejte nové heslo.";
            return;
        }

        // Validate password requirements
        if (_newPassword.Length < 8)
        {
            _passwordError = "Heslo musí mít alespoň 8 znaků.";
            return;
        }
        if (!_newPassword.Any(char.IsUpper))
        {
            _passwordError = "Heslo musí obsahovat velké písmeno.";
            return;
        }
        if (!_newPassword.Any(char.IsLower))
        {
            _passwordError = "Heslo musí obsahovat malé písmeno.";
            return;
        }
        if (!_newPassword.Any(char.IsDigit))
        {
            _passwordError = "Heslo musí obsahovat číslici.";
            return;
        }
        if (!_newPassword.Any(c => !char.IsLetterOrDigit(c)))
        {
            _passwordError = "Heslo musí obsahovat speciální znak.";
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _passwordError = "Hesla se neshodují.";
            return;
        }

        _passwordSaving = true;
        try
        {
            await Api.ChangePasswordAsync(Auth.CurrentSession.UserId, _currentPassword, _newPassword);
            _passwordSuccess = "Heslo bylo úspěšně změněno.";
            _currentPassword = "";
            _newPassword = "";
            _confirmPassword = "";

            // Auto-hide success after delay
            _ = Task.Delay(3000).ContinueWith(_ =>
            {
                _passwordSuccess = "";
                _showChangePassword = false;
                InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            _passwordError = $"Chyba při změně hesla: {ex.Message}";
        }
        finally
        {
            _passwordSaving = false;
        }
    }

    // ── Notification preferences ──

    private async Task UpdateNotifPref(Action<NotificationPreferenceDto> update)
    {
        if (_notifPrefs is null || Auth.CurrentSession is null) return;
        update(_notifPrefs);
        _notifPrefsSaveError = "";
        _notifPrefsSaved = false;
        try
        {
            await Api.UpdateNotificationPreferencesAsync(Auth.CurrentSession.UserId, _notifPrefs);
            _notifPrefsSaved = true;
            _ = Task.Delay(2000).ContinueWith(_ =>
            {
                _notifPrefsSaved = false;
                InvokeAsync(StateHasChanged);
            });
        }
        catch
        {
            _notifPrefsSaveError = "Chyba při ukládání. Zkuste to znovu.";
        }
    }

    // ── Common handlers ──

    private async Task OnDarkModeToggled(bool isDark)
    {
        await Theme.SetDarkModeAsync(isDark);
    }

    private void HandleThemeChanged() => InvokeAsync(StateHasChanged);

    private async Task HandleLogout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", forceLoad: false);
    }

    public void Dispose()
    {
        Theme.OnThemeChanged -= HandleThemeChanged;
    }
}
