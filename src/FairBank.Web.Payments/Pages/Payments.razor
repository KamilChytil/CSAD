@page "/platby"
@namespace FairBank.Web.Payments.Pages
@inject IFairBankApi Api
@inject IAuthService Auth
@inject IJSRuntime Js

<PageHeader Title="PLATBY" ShowChip="false">
    <Actions>
        <div class="page-tabs">
            <button class="page-tab @(_pageView == "platby" ? "active" : "")" @onclick='() => _pageView = "platby"'>PLATBY</button>
            <button class="page-tab @(_pageView == "pohyby" ? "active" : "")" @onclick="SwitchToPohyby">Pohyby</button>
            <button class="page-tab @(_pageView == "menu" ? "active" : "")" @onclick='() => _pageView = "menu"'>Menu</button>
        </div>
    </Actions>
</PageHeader>

<div class="page-content payments-page">

    @if (_pageView == "platby")
    {
        @* ── QUICK ACTIONS GRID ──────────────────── *@
        <ContentCard Title="Rychlé akce" CssClass="section-quick-actions">
            <Icon><VbIcon Name="utilities" Size="sm" Color="var(--vb-red)" /></Icon>
            <ChildContent>
                <div class="quick-actions">
                    <button class="quick-action-btn" @onclick='() => SetTab("payment")'>
                        <div class="quick-action-icon"><VbIcon Name="send" Size="md" /></div>
                        <span>Poslat</span>
                    </button>
                    <button class="quick-action-btn" @onclick='() => SetTab("payment")'>
                        <div class="quick-action-icon"><VbIcon Name="qr" Size="md" /></div>
                        <span>QR Platba</span>
                    </button>
                    <button class="quick-action-btn" @onclick='() => SetTab("standing")'>
                        <div class="quick-action-icon"><VbIcon Name="clock" Size="md" /></div>
                        <span>Trvalý příkaz</span>
                    </button>
                    <button class="quick-action-btn" @onclick='() => SetTab("templates")'>
                        <div class="quick-action-icon"><VbIcon Name="star" Size="md" /></div>
                        <span>Šablony</span>
                    </button>
                    <button class="quick-action-btn" @onclick='() => SetTab("transfer")'>
                        <div class="quick-action-icon"><VbIcon Name="transfer" Size="md" /></div>
                        <span>Převod</span>
                    </button>
                    <button class="quick-action-btn" @onclick='() => SetTab("international")'>
                        <div class="quick-action-icon"><VbIcon Name="utilities" Size="md" /></div>
                        <span>Zahraniční</span>
                    </button>
                </div>
            </ChildContent>
        </ContentCard>

        @* ── CONTACTS FOR TRANSFER ───────────────── *@
        <ContentCard Title="KONTAKTY PRO PŘEVOD">
            <Icon><VbIcon Name="user" Size="sm" Color="var(--vb-red)" /></Icon>
            <HeaderAction><button class="link-action" @onclick='() => SetTab("templates")'>Spravovat</button></HeaderAction>
            <ChildContent>
                <div class="contacts-row">
                    @foreach (var contact in _contacts)
                    {
                        <button class="contact-chip" @onclick="() => UseContact(contact)">
                            <div class="contact-avatar">@contact.Initials</div>
                            <span class="contact-name">@contact.Name</span>
                        </button>
                    }
                    <button class="contact-chip contact-add" @onclick='() => SetTab("templates")'>
                        <div class="contact-avatar"><VbIcon Name="plus" Size="xs" /></div>
                        <span class="contact-name">Přidat</span>
                    </button>
                </div>
            </ChildContent>
        </ContentCard>

        @* ── PAYMENT CALENDAR ────────────────────── *@
        <ContentCard Title="KALENDÁŘ PLATEB" CssClass="section-calendar">
            <Icon><VbIcon Name="clock" Size="sm" Color="var(--vb-red)" /></Icon>
            <ChildContent>
                <div class="calendar-widget">
                    <div class="calendar-header">
                        <button class="calendar-nav" @onclick="PrevMonth">&lt;</button>
                        <span class="calendar-month">@_calendarDate.ToString("MMMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ"))</span>
                        <button class="calendar-nav" @onclick="NextMonth">&gt;</button>
                    </div>
                    <div class="calendar-grid">
                        @foreach (var day in new[] { "Po", "Út", "St", "Čt", "Pá", "So", "Ne" })
                        {
                            <span class="calendar-day-header">@day</span>
                        }
                        @foreach (var day in GetCalendarDays())
                        {
                            var hasPayment = _upcomingPaymentDays.Contains(day.Day) && day.Month == _calendarDate.Month;
                            <button class="calendar-day @(day.Month != _calendarDate.Month ? "other-month" : "") @(day.Date == DateTime.Today ? "today" : "") @(hasPayment ? "has-payment" : "")">
                                @day.Day
                            </button>
                        }
                    </div>
                    @if (_standingOrders.Any(s => s.IsActive))
                    {
                        <div class="calendar-upcoming">
                            <span class="calendar-upcoming-title">Nadcházející platby</span>
                            @foreach (var so in _standingOrders.Where(s => s.IsActive).Take(3))
                            {
                                <div class="calendar-event">
                                    <span class="calendar-event-date">@so.NextExecutionDate.ToString("dd.MM.")</span>
                                    <span class="calendar-event-desc">@so.Description — @so.Amount.ToString("N0") @so.Currency</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </ChildContent>
        </ContentCard>
    }

    @if (_pageView == "pohyby")
    {
        @* ── BALANCE HERO IN POHYBY VIEW ─────────── *@
        <BalanceCard Amount="@_accountBalance" Currency="Kč" Variant="hero" Label="ZŮSTATEK" />

        <div class="stat-row" style="margin-bottom:12px;">
            <div class="stat-item">
                <div class="stat-value" style="color:var(--vb-red);">-@TotalSent.ToString("N0")</div>
                <div class="stat-label">Odesláno</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" style="color:var(--vb-green);">+@TotalReceived.ToString("N0")</div>
                <div class="stat-label">Přijato</div>
            </div>
            <div class="stat-item">
                <div class="stat-value">@CompletedHistory.Count</div>
                <div class="stat-label">Transakcí</div>
            </div>
        </div>

        <div class="statement-controls">
            <div class="statement-inputs">
                <label>Od:<InputDate class="form-input" @bind-Value="_statementFrom" /></label>
                <label>Do:<InputDate class="form-input" @bind-Value="_statementTo" /></label>
                <label>Format:
                    <select class="form-input" @bind="_statementFormat">
                        <option value="pdf">PDF</option>
                        <option value="docx">DOCX</option>
                        <option value="xlsx">Excel</option>
                    </select>
                </label>
            </div>
            <div class="statement-actions">
                <VbButton Variant="outline" OnClick="DownloadStatement">Stáhnout výpis</VbButton>
            </div>
        </div>

        @* ── FILTER TABS ─────────────────────────── *@
        <div class="tab-bar" style="margin-bottom:8px;">
            <button class="tab-btn @(_historyFilter == "all" ? "active" : "")" @onclick='() => _historyFilter = "all"'>Vše</button>
            <button class="tab-btn @(_historyFilter == "sent" ? "active" : "")" @onclick='() => _historyFilter = "sent"'>Odeslané</button>
            <button class="tab-btn @(_historyFilter == "received" ? "active" : "")" @onclick='() => _historyFilter = "received"'>Přijaté</button>
        </div>

        @* ── TRANSACTION LIST ────────────────────── *@
        <ContentCard Title="TRANSAKCE">
            <Icon><VbIcon Name="transfer" Size="sm" Color="var(--vb-red)" /></Icon>
            <ChildContent>
                @foreach (var tx in GetFilteredHistory())
                {
                    var isSent = tx.SenderAccountId == _selectedAccountId;
                    var counterparty = isSent ? tx.RecipientAccountNumber : tx.SenderAccountNumber;
                    var statusBadge = tx.Status switch { "Completed" => "✓", "Failed" => "✗", "Pending" => "⏳", _ => "" };
                    <TransactionItem
                        Description="@($"{(isSent ? "→" : "←")} {counterparty}{(string.IsNullOrWhiteSpace(tx.Description) ? "" : $": {tx.Description}")} {statusBadge}")"
                        Date="@tx.CreatedAt"
                        Amount="@(isSent ? -tx.Amount : tx.Amount)"
                        Currency="Kč"
                        Type="@(isSent ? "withdrawal" : "deposit")"
                        Category="@GetCategory(tx.Description)" />
                }
                @if (!_history.Any())
                {
                    <p class="empty-state">Zatím žádné platby</p>
                }
            </ChildContent>
        </ContentCard>
    }

    @if (_pageView == "menu")
    {
        @* ── TAB NAVIGATION ─────────────────────── *@
        <div class="tab-bar">
            <button class="tab-btn @(_activeTab == "payment" ? "active" : "")" @onclick='() => SetTab("payment")'>
                <VbIcon Name="send" Size="xs" /> Nová platba
            </button>
            <button class="tab-btn @(_activeTab == "transfer" ? "active" : "")" @onclick='() => SetTab("transfer")'>
                <VbIcon Name="transfer" Size="xs" /> Převod
            </button>
            <button class="tab-btn @(_activeTab == "international" ? "active" : "")" @onclick='() => SetTab("international")'>
                <VbIcon Name="utilities" Size="xs" /> Zahraniční
            </button>
            <button class="tab-btn @(_activeTab == "standing" ? "active" : "")" @onclick='() => SetTab("standing")'>
                <VbIcon Name="clock" Size="xs" /> Trvalé příkazy
            </button>
            <button class="tab-btn @(_activeTab == "templates" ? "active" : "")" @onclick='() => SetTab("templates")'>
                <VbIcon Name="star" Size="xs" /> Šablony
            </button>
        </div>

        @* ── NEW PAYMENT ──────────────────────── *@
        @if (_activeTab == "payment")
        {
            <ContentCard Title="Nová platba">
                <Icon><VbIcon Name="send" Size="sm" Color="var(--vb-red)" /></Icon>
                <ChildContent>
                    @if (_templates.Any())
                    {
                        <div class="form-group">
                            <label class="form-label">Použít šablonu</label>
                            <select class="form-input" @onchange="OnTemplateSelected">
                                <option value="">— vyberte šablonu —</option>
                                @foreach (var t in _templates)
                                {
                                    <option value="@t.Id">@t.Name (@t.RecipientAccountNumber)</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="form-group">
                        <label class="form-label">Číslo účtu příjemce</label>
                        <div class="account-number-row">
                            <input class="form-input account-prefix" @bind="_recipientPrefix" @onblur="ValidateAccountNumber" placeholder="000000" maxlength="6" />
                            <span class="account-sep">-</span>
                            <input class="form-input account-number" @bind="_recipientNumber" @onblur="ValidateAccountNumber" placeholder="0000000000" maxlength="10" />
                            <span class="account-sep">/</span>
                            <select class="form-input account-bank" @bind="_recipientBankCode">
                                @foreach (var bank in BankCodes)
                                {
                                    <option value="@bank.Code">@bank.Code — @bank.Name</option>
                                }
                            </select>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_accountNumberError))
                        {
                            <span class="field-error">@_accountNumberError</span>
                        }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Částka</label>
                        <div class="input-with-suffix">
                            <input class="form-input" type="number" @bind="_amount" placeholder="0" min="1" />
                            <span class="input-suffix">Kč</span>
                        </div>
                        @if (_amount < 0)
                        {
                            <span class="field-error">Částka musí být kladná</span>
                        }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Popis</label>
                        <input class="form-input" @bind="_description" placeholder="Volitelný popis platby" />
                    </div>
                    <VbButton OnClick="RequestPayment" FullWidth="true" Disabled="@(!CanSendPayment() || _isLoading)">
                        @if (_isLoading) { <span>Odesílám...</span> } else { <span>Odeslat platbu</span> }
                    </VbButton>
                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <div class="error-banner">@_errorMessage</div>
                    }
                    @if (_paymentSuccess)
                    {
                        <div class="success-banner"><VbIcon Name="shield" Size="xs" /> Platba úspěšně odeslána</div>
                    }
                </ChildContent>
            </ContentCard>
        }

        @* ── INTERNAL TRANSFER ──────────────────── *@
        @if (_activeTab == "transfer")
        {
            <ContentCard Title="Převod mezi účty">
                <Icon><VbIcon Name="transfer" Size="sm" Color="var(--vb-red)" /></Icon>
                <ChildContent>
                    <div class="form-group">
                        <label class="form-label">Z účtu</label>
                        <select class="form-input" @bind="_transferFromAccountId">
                            <option value="">— vyberte účet —</option>
                            @foreach (var acc in _accounts)
                            {
                                <option value="@acc.Id">@acc.AccountNumber (@acc.Balance.ToString("N0") @acc.Currency)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Na účet</label>
                        <select class="form-input" @bind="_transferToAccountNumber">
                            <option value="">— vyberte cílový účet —</option>
                            @foreach (var acc in _accounts.Where(a => a.Id.ToString() != _transferFromAccountId))
                            {
                                <option value="@acc.AccountNumber">@acc.AccountNumber (@acc.Balance.ToString("N0") @acc.Currency)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Částka</label>
                        <div class="input-with-suffix">
                            <input class="form-input" type="number" @bind="_transferAmount" placeholder="0" />
                            <span class="input-suffix">Kč</span>
                        </div>
                    </div>
                    <VbButton OnClick="SendTransfer" FullWidth="true" Disabled="@(_transferAmount <= 0 || string.IsNullOrWhiteSpace(_transferFromAccountId) || string.IsNullOrWhiteSpace(_transferToAccountNumber) || _isLoading)">
                        @if (_isLoading) { <span>Převádím...</span> } else { <span>Převést</span> }
                    </VbButton>
                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <div class="error-banner">@_errorMessage</div>
                    }
                    @if (_paymentSuccess)
                    {
                        <div class="success-banner"><VbIcon Name="shield" Size="xs" /> Převod úspěšně proveden</div>
                    }
                </ChildContent>
            </ContentCard>
        }

        @* ── STANDING ORDER ─────────────────────── *@
        @if (_activeTab == "standing")
        {
            <ContentCard Title="Nový trvalý příkaz">
                <Icon><VbIcon Name="clock" Size="sm" Color="var(--vb-red)" /></Icon>
                <ChildContent>
                    <div class="form-group">
                        <label class="form-label">Číslo účtu příjemce</label>
                        <div class="account-number-row">
                            <input class="form-input account-prefix" @bind="_soPrefix" placeholder="000000" maxlength="6" />
                            <span class="account-sep">-</span>
                            <input class="form-input account-number" @bind="_soNumber" placeholder="0000000000" maxlength="10" />
                            <span class="account-sep">/</span>
                            <select class="form-input account-bank" @bind="_soBankCode">
                                @foreach (var bank in BankCodes)
                                {
                                    <option value="@bank.Code">@bank.Code — @bank.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Částka</label>
                        <div class="input-with-suffix">
                            <input class="form-input" type="number" @bind="_soAmount" placeholder="0" />
                            <span class="input-suffix">Kč</span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Popis</label>
                        <input class="form-input" @bind="_soDescription" placeholder="Např. Nájem" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Interval</label>
                        <select class="form-input" @bind="_soInterval">
                            <option value="Daily">Denně</option>
                            <option value="Weekly">Týdně</option>
                            <option value="Monthly">Měsíčně</option>
                            <option value="Quarterly">Čtvrtletně</option>
                            <option value="Yearly">Ročně</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">První platba</label>
                        <input class="form-input" type="date" @bind="_soFirstDate" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Konec (volitelné)</label>
                        <input class="form-input" type="date" @bind="_soEndDate" />
                    </div>
                    <VbButton OnClick="CreateStandingOrder" FullWidth="true" Disabled="@(_soAmount <= 0 || string.IsNullOrWhiteSpace(_soNumber) || _isLoading)">
                        @if (_isLoading) { <span>Vytvářím...</span> } else { <span>Vytvořit trvalý příkaz</span> }
                    </VbButton>
                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <div class="error-banner">@_errorMessage</div>
                    }
                    @if (_paymentSuccess)
                    {
                        <div class="success-banner"><VbIcon Name="shield" Size="xs" /> Trvalý příkaz vytvořen</div>
                    }
                </ChildContent>
            </ContentCard>

            <ContentCard Title="Aktivní trvalé příkazy">
                <Icon><VbIcon Name="clock" Size="sm" Color="var(--vb-gold)" /></Icon>
                <ChildContent>
                    @foreach (var so in _standingOrders.Where(s => s.IsActive))
                    {
                        <div class="standing-order-item">
                            <div class="so-details">
                                <span class="so-recipient">→ @so.RecipientAccountNumber</span>
                                <span class="so-info">@so.Amount.ToString("N0") @so.Currency · @FormatInterval(so.Interval) · další: @so.NextExecutionDate.ToString("dd.MM.yyyy")</span>
                                @if (!string.IsNullOrWhiteSpace(so.Description))
                                {
                                    <span class="so-desc">@so.Description</span>
                                }
                            </div>
                            <VbButton Variant="danger" Size="sm" OnClick="() => CancelStandingOrder(so.Id)">Zrušit</VbButton>
                        </div>
                    }
                    @if (!_standingOrders.Any(s => s.IsActive))
                    {
                        <p class="empty-state">Žádné aktivní trvalé příkazy</p>
                    }
                </ChildContent>
            </ContentCard>
        }

        @* ── INTERNATIONAL PAYMENT ────────────── *@
        @if (_activeTab == "international")
        {
            <ContentCard Title="Zahraniční platba">
                <Icon><VbIcon Name="utilities" Size="sm" Color="var(--vb-red)" /></Icon>
                <ChildContent>
                    <div class="form-group">
                        <label class="form-label">IBAN příjemce</label>
                        <input class="form-input" @bind="_intlIban" placeholder="CZ65 0800 0000 1920 0014 5399" maxlength="34" />
                        @if (!string.IsNullOrWhiteSpace(_intlIbanError))
                        {
                            <span class="field-error">@_intlIbanError</span>
                        }
                    </div>
                    <div class="form-group">
                        <label class="form-label">SWIFT / BIC</label>
                        <input class="form-input" @bind="_intlSwift" placeholder="GIBACZPX" maxlength="11" />
                        @if (!string.IsNullOrWhiteSpace(_intlSwiftError))
                        {
                            <span class="field-error">@_intlSwiftError</span>
                        }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Jméno příjemce</label>
                        <input class="form-input" @bind="_intlBeneficiary" placeholder="Jan Novák" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Adresa příjemce (volitelné)</label>
                        <input class="form-input" @bind="_intlBeneficiaryAddress" placeholder="Ulice 123, Praha" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Částka</label>
                        <div class="input-with-suffix">
                            <input class="form-input" type="number" @bind="_intlAmount" placeholder="0" min="1" />
                            <select class="form-input currency-select" @bind="_intlCurrency">
                                <option value="EUR">EUR</option>
                                <option value="USD">USD</option>
                                <option value="GBP">GBP</option>
                                <option value="CZK">CZK</option>
                                <option value="CHF">CHF</option>
                                <option value="PLN">PLN</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Popis platby</label>
                        <input class="form-input" @bind="_intlDescription" placeholder="Účel platby" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Poplatek</label>
                        <select class="form-input" @bind="_intlChargeType">
                            <option value="SHA">SHA — sdílené poplatky</option>
                            <option value="OUR">OUR — všechny poplatky plátce</option>
                            <option value="BEN">BEN — všechny poplatky příjemce</option>
                        </select>
                    </div>
                    <VbButton OnClick="SendInternationalPayment" FullWidth="true" Disabled="@(!IsIntlFormValid() || _isLoading)">
                        @if (_isLoading) { <span>Odesílám...</span> } else { <span>Odeslat zahraniční platbu</span> }
                    </VbButton>
                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <div class="error-banner">@_errorMessage</div>
                    }
                    @if (_paymentSuccess)
                    {
                        <div class="success-banner"><VbIcon Name="shield" Size="xs" /> Zahraniční platba odeslána</div>
                    }
                </ChildContent>
            </ContentCard>
        }

        @* ── TEMPLATES ──────────────────────────── *@
        @if (_activeTab == "templates")
        {
            <ContentCard Title="Nová šablona">
                <Icon><VbIcon Name="star" Size="sm" Color="var(--vb-red)" /></Icon>
                <ChildContent>
                    <div class="form-group">
                        <label class="form-label">Název šablony</label>
                        <input class="form-input" @bind="_tplName" placeholder="Např. Nájem" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Číslo účtu příjemce</label>
                        <div class="account-number-row">
                            <input class="form-input account-prefix" @bind="_tplPrefix" placeholder="000000" maxlength="6" />
                            <span class="account-sep">-</span>
                            <input class="form-input account-number" @bind="_tplNumber" placeholder="0000000000" maxlength="10" />
                            <span class="account-sep">/</span>
                            <select class="form-input account-bank" @bind="_tplBankCode">
                                @foreach (var bank in BankCodes)
                                {
                                    <option value="@bank.Code">@bank.Code — @bank.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Jméno příjemce (volitelné)</label>
                        <input class="form-input" @bind="_tplRecipientName" placeholder="Jan Novák" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Výchozí částka (volitelné)</label>
                        <div class="input-with-suffix">
                            <input class="form-input" type="number" @bind="_tplAmount" placeholder="0" />
                            <span class="input-suffix">Kč</span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Výchozí popis (volitelné)</label>
                        <input class="form-input" @bind="_tplDescription" placeholder="Popis platby" />
                    </div>
                    <VbButton OnClick="CreateTemplate" FullWidth="true" Disabled="@(string.IsNullOrWhiteSpace(_tplName) || string.IsNullOrWhiteSpace(_tplNumber) || _isLoading)">
                        @if (_isLoading) { <span>Ukládám...</span> } else { <span>Uložit šablonu</span> }
                    </VbButton>
                    @if (_paymentSuccess)
                    {
                        <div class="success-banner"><VbIcon Name="shield" Size="xs" /> Šablona uložena</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <div class="error-banner">@_errorMessage</div>
                    }
                </ChildContent>
            </ContentCard>

            <ContentCard Title="Uložené šablony">
                <Icon><VbIcon Name="star" Size="sm" Color="var(--vb-gold)" /></Icon>
                <ChildContent>
                    @foreach (var tpl in _templates)
                    {
                        <div class="template-item">
                            <div class="tpl-details">
                                <span class="tpl-name">@tpl.Name</span>
                                <span class="tpl-info">→ @tpl.RecipientAccountNumber @(tpl.RecipientName is not null ? $"({tpl.RecipientName})" : "")</span>
                                @if (tpl.DefaultAmount.HasValue)
                                {
                                    <span class="tpl-amount">@tpl.DefaultAmount.Value.ToString("N0") @tpl.Currency</span>
                                }
                            </div>
                            <div class="tpl-actions">
                                <VbButton Variant="outline" Size="sm" OnClick="() => UseTemplate(tpl)">Použít</VbButton>
                                <VbButton Variant="danger" Size="sm" OnClick="() => DeleteTemplate(tpl.Id)">Smazat</VbButton>
                            </div>
                        </div>
                    }
                    @if (!_templates.Any())
                    {
                        <p class="empty-state">Žádné uložené šablony</p>
                    }
                </ChildContent>
            </ContentCard>
        }
    }

    @* ── PAYMENT CONFIRM MODAL ─────────────────────── *@
    @if (_showConfirmModal)
    {
        <div class="confirm-overlay" @onclick="CancelPayment">
            <div class="confirm-dialog" @onclick:stopPropagation="true">
                <h3 class="confirm-title"><VbIcon Name="send" Size="sm" Color="var(--vb-red)" />&nbsp;Potvrdit platbu</h3>
                <div class="confirm-detail">
                    <div class="confirm-row">
                        <span>Příjemce:</span>
                        <strong>@_pendingRecipient</strong>
                    </div>
                    <div class="confirm-row confirm-amount">
                        <span>Částka:</span>
                        <strong>@_pendingAmount.ToString("N2") Kč</strong>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_pendingDescription))
                    {
                        <div class="confirm-row">
                            <span>Popis:</span>
                            <strong>@_pendingDescription</strong>
                        </div>
                    }
                </div>
                <div class="confirm-actions">
                    <VbButton Variant="outline" OnClick="CancelPayment" Disabled="@_isLoading">Zrušit</VbButton>
                    <VbButton OnClick="ConfirmPayment" Disabled="@_isLoading">
                        @if (_isLoading) { <span>Odesílám...</span> } else { <span>Potvrdit platbu</span> }
                    </VbButton>
                </div>
            </div>
        </div>
    }

</div>

@code {
    private string _pageView = "platby";
    private string _activeTab = "payment";
    private bool _isLoading;
    private string _errorMessage = "";
    private bool _paymentSuccess;

    // Confirm modal
    private bool _showConfirmModal;
    private string _pendingRecipient = "";
    private decimal _pendingAmount;
    private string _pendingDescription = "";

    // Calendar
    private DateTime _calendarDate = DateTime.Today;
    private HashSet<int> _upcomingPaymentDays = [];

    // History filter
    private string _historyFilter = "all";

    // Account data
    private List<AccountResponse> _accounts = [];
    private Guid? _selectedAccountId;
    private string _selectedAccountCurrency = "CZK";
    private decimal _accountBalance;

    // Statement export controls
    private DateTime? _statementFrom;
    private DateTime? _statementTo;
    private string _statementFormat = "pdf";

    // ── New payment (split account number) ──
    private string _recipientPrefix = "";
    private string _recipientNumber = "";
    private string _recipientBankCode = "8888";
    private decimal _amount;
    private string _description = "";
    private string _accountNumberError = "";

    // Internal transfer
    private string _transferFromAccountId = "";
    private string _transferToAccountNumber = "";
    private decimal _transferAmount;

    // Standing order (split account number)
    private string _soPrefix = "";
    private string _soNumber = "";
    private string _soBankCode = "8888";
    private decimal _soAmount;
    private string _soDescription = "";
    private string _soInterval = "Monthly";
    private DateTime _soFirstDate = DateTime.Today.AddDays(1);
    private DateTime? _soEndDate;

    // Templates (split account number)
    private string _tplName = "";
    private string _tplPrefix = "";
    private string _tplNumber = "";
    private string _tplBankCode = "8888";
    private string _tplRecipientName = "";
    private decimal? _tplAmount;
    private string _tplDescription = "";

    // International payment
    private string _intlIban = "";
    private string _intlSwift = "";
    private string _intlBeneficiary = "";
    private string _intlBeneficiaryAddress = "";
    private decimal _intlAmount;
    private string _intlCurrency = "EUR";
    private string _intlDescription = "";
    private string _intlChargeType = "SHA";
    private string _intlIbanError = "";
    private string _intlSwiftError = "";

    // Helpers for summary and filtering
    private List<PaymentDto> CompletedHistory => _history.Where(h => h.Status == "Completed").ToList();
    private decimal TotalSent => CompletedHistory.Where(h => h.SenderAccountId == _selectedAccountId).Sum(h => h.Amount);
    private decimal TotalReceived => CompletedHistory.Where(h => h.SenderAccountId != _selectedAccountId).Sum(h => h.Amount);

    private List<PaymentDto> GetFilteredHistory() => _historyFilter switch
    {
        "sent" => _history.Where(h => h.SenderAccountId == _selectedAccountId).ToList(),
        "received" => _history.Where(h => h.SenderAccountId != _selectedAccountId).ToList(),
        _ => _history
    };

    // Data
    private List<PaymentDto> _history = [];
    private List<StandingOrderDto> _standingOrders = [];
    private List<PaymentTemplateDto> _templates = [];
    private List<ContactVm> _contacts = [];

    // ── Czech bank codes ──
    private static readonly BankCodeEntry[] BankCodes =
    [
        new("0100", "Komerční banka"),
        new("0300", "ČSOB"),
        new("0600", "Moneta Money Bank"),
        new("0710", "ČNB"),
        new("0800", "Česká spořitelna"),
        new("2010", "Fio banka"),
        new("2700", "UniCredit Bank"),
        new("3030", "Air Bank"),
        new("3500", "ING Bank"),
        new("5500", "Raiffeisenbank"),
        new("5800", "J&T Banka"),
        new("6000", "PPF banka"),
        new("6100", "Equa bank"),
        new("6200", "CREDITAS"),
        new("6210", "mBank"),
        new("8040", "Oberbank"),
        new("8060", "Česká exportní banka"),
        new("8150", "HSBC"),
        new("8888", "FairBank"),
    ];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var session = Auth.CurrentSession;
            if (session is null) return;

            _accounts = await Api.GetAccountsByOwnerAsync(session.UserId);
            if (_accounts.Any())
            {
                _selectedAccountId = _accounts[0].Id;
                _selectedAccountCurrency = _accounts[0].Currency;
                _accountBalance = _accounts[0].Balance;
                await LoadData();
            }
        }
        catch
        {
            // Silently handle – data will be empty
        }

        // Build contacts from templates
        _contacts = _templates.Select(t => new ContactVm(
            t.RecipientName ?? t.Name,
            GetInitials(t.RecipientName ?? t.Name),
            t.RecipientAccountNumber
        )).Take(6).ToList();

        // Add demo contacts if none exist
        if (!_contacts.Any())
        {
            _contacts =
            [
                new("Jan N.", "JN", "000000-0010010001/0100"),
                new("Marie K.", "MK", "000000-0010020003/0300"),
                new("Petr V.", "PV", "000000-0020010001/0800"),
                new("Anna S.", "AS", "000000-0030010001/8888"),
            ];
        }

        // Populate calendar payment days from standing orders
        foreach (var so in _standingOrders.Where(s => s.IsActive))
        {
            _upcomingPaymentDays.Add(so.NextExecutionDate.Day);
        }
        if (!_upcomingPaymentDays.Any())
        {
            _upcomingPaymentDays = [1, 5, 15, 20, 25];
        }
    }

    private async Task LoadData()
    {
        if (_selectedAccountId is null) return;
        try
        {
            var historyTask = Api.GetPaymentsByAccountAsync(_selectedAccountId.Value);
            var standingTask = Api.GetStandingOrdersByAccountAsync(_selectedAccountId.Value);
            var templatesTask = Api.GetPaymentTemplatesByAccountAsync(_selectedAccountId.Value);
            await Task.WhenAll(historyTask, standingTask, templatesTask);
            _history = historyTask.Result;
            _standingOrders = standingTask.Result;
            _templates = templatesTask.Result;
        }
        catch
        {
            // Keep existing data on failure
        }
    }

    private void SetTab(string tab)
    {
        _activeTab = tab;
        _pageView = "menu";
        _errorMessage = "";
        _paymentSuccess = false;
        _accountNumberError = "";
        _intlIbanError = "";
        _intlSwiftError = "";
    }

    private async Task SwitchToPohyby()
    {
        _pageView = "pohyby";
        _historyFilter = "all";
        // Refresh balance and history
        try
        {
            var session = Auth.CurrentSession;
            if (session is not null)
            {
                _accounts = await Api.GetAccountsByOwnerAsync(session.UserId);
                if (_accounts.Any())
                {
                    _selectedAccountId = _accounts[0].Id;
                    _accountBalance = _accounts[0].Balance;
                }
            }
            await LoadData();
        }
        catch { /* keep existing data */ }
    }

    private async Task DownloadStatement()
    {
        if (_selectedAccountId is null) return;
        try
        {
            var bytes = await Api.DownloadStatementAsync(_selectedAccountId.Value, _statementFrom, _statementTo, _statementFormat);
            var base64 = Convert.ToBase64String(bytes);
            await Js.InvokeVoidAsync("vabank.downloadFile", base64, $"statement-{_selectedAccountId}.{_statementFormat}");
        }
        catch
        {
            // ignore failure
        }
    }

    // ── Account number helpers ──
    private static string ComposeAccountNumber(string prefix, string number, string bankCode)
    {
        var pfx = string.IsNullOrWhiteSpace(prefix) ? "000000" : prefix.PadLeft(6, '0');
        return $"{pfx}-{number}/{bankCode}";
    }

    private void ParseAccountNumberToFields(string accountNumber, out string prefix, out string number, out string bankCode)
    {
        prefix = "000000";
        number = "";
        bankCode = "8888";

        if (string.IsNullOrWhiteSpace(accountNumber)) return;

        // Expected format: 000000-1234567890/8888
        var slashIdx = accountNumber.IndexOf('/');
        if (slashIdx > 0 && slashIdx < accountNumber.Length - 1)
        {
            bankCode = accountNumber[(slashIdx + 1)..];
            var leftPart = accountNumber[..slashIdx];
            var dashIdx = leftPart.IndexOf('-');
            if (dashIdx > 0)
            {
                prefix = leftPart[..dashIdx];
                number = leftPart[(dashIdx + 1)..];
            }
            else
            {
                number = leftPart;
            }
        }
        else
        {
            number = accountNumber;
        }
    }

    // ── Validation ──
    private bool IsPaymentFormValid()
    {
        if (_amount <= 0) return false;
        if (string.IsNullOrWhiteSpace(_recipientNumber)) return false;
        if (!_recipientNumber.All(char.IsDigit)) { _accountNumberError = "Číslo účtu musí obsahovat pouze číslice"; return false; }
        if (_recipientNumber.Length < 2 || _recipientNumber.Length > 10) { _accountNumberError = "Číslo účtu: 2–10 číslic"; return false; }
        if (!string.IsNullOrWhiteSpace(_recipientPrefix) && (!_recipientPrefix.All(char.IsDigit) || _recipientPrefix.Length > 6))
        { _accountNumberError = "Předčíslí: max 6 číslic"; return false; }
        _accountNumberError = "";
        return true;
    }

    private bool IsIntlFormValid()
    {
        if (_intlAmount <= 0) return false;
        if (string.IsNullOrWhiteSpace(_intlBeneficiary)) return false;

        // Basic IBAN check
        var iban = _intlIban.Replace(" ", "").ToUpper();
        if (iban.Length < 15 || iban.Length > 34) { _intlIbanError = "IBAN: 15–34 znaků"; return false; }
        if (!System.Text.RegularExpressions.Regex.IsMatch(iban, @"^[A-Z]{2}\d{2}[A-Z0-9]+$")) { _intlIbanError = "Neplatný formát IBAN"; return false; }
        _intlIbanError = "";

        // SWIFT/BIC check
        var swift = _intlSwift.Replace(" ", "").ToUpper();
        if (swift.Length is not (8 or 11)) { _intlSwiftError = "SWIFT/BIC: 8 nebo 11 znaků"; return false; }
        if (!System.Text.RegularExpressions.Regex.IsMatch(swift, @"^[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}([A-Z0-9]{3})?$")) { _intlSwiftError = "Neplatný formát SWIFT"; return false; }
        _intlSwiftError = "";

        return true;
    }

    // Calendar helpers
    private void PrevMonth() => _calendarDate = _calendarDate.AddMonths(-1);
    private void NextMonth() => _calendarDate = _calendarDate.AddMonths(1);

    private List<DateTime> GetCalendarDays()
    {
        var first = new DateTime(_calendarDate.Year, _calendarDate.Month, 1);
        var startDay = (int)first.DayOfWeek;
        if (startDay == 0) startDay = 7;
        var start = first.AddDays(-(startDay - 1));
        var days = new List<DateTime>();
        for (var i = 0; i < 42; i++)
            days.Add(start.AddDays(i));
        return days;
    }

    private void UseContact(ContactVm contact)
    {
        ParseAccountNumberToFields(contact.AccountNumber, out var pfx, out var num, out var bank);
        _recipientPrefix = pfx;
        _recipientNumber = num;
        _recipientBankCode = bank;
        _activeTab = "payment";
        _pageView = "menu";
    }

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private static string GetCategory(string? description)
    {
        if (string.IsNullOrWhiteSpace(description)) return "";
        var d = description.ToLowerInvariant();
        if (d.Contains("nákup") || d.Contains("shop")) return "shopping";
        if (d.Contains("restaur") || d.Contains("jídlo")) return "food";
        if (d.Contains("benzín") || d.Contains("auto")) return "car";
        if (d.Contains("dovolená") || d.Contains("hotel")) return "travel";
        if (d.Contains("elektřin") || d.Contains("plyn")) return "utilities";
        return "";
    }

    // ── Actions ──
    private bool CanSendPayment() => _amount > 0 && !string.IsNullOrWhiteSpace(_recipientNumber);

    private void ValidateAccountNumber()
    {
        if (string.IsNullOrWhiteSpace(_recipientNumber)) { _accountNumberError = ""; return; }
        if (!_recipientNumber.All(char.IsDigit)) { _accountNumberError = "Číslo účtu musí obsahovat pouze číslice"; return; }
        if (_recipientNumber.Length < 2 || _recipientNumber.Length > 10) { _accountNumberError = "Číslo účtu: 2–10 číslic"; return; }
        if (!string.IsNullOrWhiteSpace(_recipientPrefix) && (!_recipientPrefix.All(char.IsDigit) || _recipientPrefix.Length > 6))
        { _accountNumberError = "Předčíslí: max 6 číslic"; return; }
        _accountNumberError = "";
    }

    private void RequestPayment()
    {
        ValidateAccountNumber();
        if (!IsPaymentFormValid() || _selectedAccountId is null) return;

        _pendingRecipient = ComposeAccountNumber(_recipientPrefix, _recipientNumber, _recipientBankCode);
        _pendingAmount = _amount;
        _pendingDescription = _description;
        _errorMessage = "";
        _paymentSuccess = false;
        _showConfirmModal = true;
    }

    private async Task ConfirmPayment()
    {
        if (_selectedAccountId is null) return;

        _isLoading = true;
        _errorMessage = "";
        _paymentSuccess = false;

        try
        {
            await Api.SendPaymentAsync(_selectedAccountId.Value, _pendingRecipient, _pendingAmount, _selectedAccountCurrency, _pendingDescription);
            _paymentSuccess = true;
            _amount = 0;
            _description = "";
            _recipientPrefix = "";
            _recipientNumber = "";
            _accountNumberError = "";
            _showConfirmModal = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message.Contains("Insufficient") ? "Nedostatek prostředků na účtu." : "Platba se nezdařila. Zkuste to znovu.";
            _showConfirmModal = false;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void CancelPayment()
    {
        _showConfirmModal = false;
        _pendingRecipient = "";
        _pendingAmount = 0;
        _pendingDescription = "";
    }

    private async Task SendPayment()
    {
        // Legacy — kept for compatibility; delegates to confirm flow
        RequestPayment();
        await Task.CompletedTask;
    }

    private async Task SendTransfer()
    {
        if (_transferAmount <= 0 || string.IsNullOrWhiteSpace(_transferFromAccountId) || string.IsNullOrWhiteSpace(_transferToAccountNumber)) return;

        _isLoading = true;
        _errorMessage = "";
        _paymentSuccess = false;

        try
        {
            var fromId = Guid.Parse(_transferFromAccountId);
            await Api.SendPaymentAsync(fromId, _transferToAccountNumber, _transferAmount, _selectedAccountCurrency, "Převod mezi vlastními účty");
            _paymentSuccess = true;
            _transferAmount = 0;
            _transferFromAccountId = "";
            _transferToAccountNumber = "";
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message.Contains("Insufficient") ? "Nedostatek prostředků na účtu." : "Převod se nezdařil. Zkuste to znovu.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CreateStandingOrder()
    {
        if (_soAmount <= 0 || string.IsNullOrWhiteSpace(_soNumber) || _selectedAccountId is null) return;

        _isLoading = true;
        _errorMessage = "";
        _paymentSuccess = false;

        try
        {
            var fullAccountNumber = ComposeAccountNumber(_soPrefix, _soNumber, _soBankCode);
            await Api.CreateStandingOrderAsync(_selectedAccountId.Value, fullAccountNumber, _soAmount, _selectedAccountCurrency, _soInterval, _soFirstDate, _soDescription, _soEndDate);
            _paymentSuccess = true;
            _soPrefix = "";
            _soNumber = "";
            _soAmount = 0;
            _soDescription = "";
            _soEndDate = null;
            await LoadData();
        }
        catch
        {
            _errorMessage = "Vytvoření trvalého příkazu se nezdařilo.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CancelStandingOrder(Guid id)
    {
        try
        {
            await Api.CancelStandingOrderAsync(id);
            await LoadData();
        }
        catch
        {
            _errorMessage = "Zrušení trvalého příkazu se nezdařilo.";
        }
    }

    private async Task CreateTemplate()
    {
        if (string.IsNullOrWhiteSpace(_tplName) || string.IsNullOrWhiteSpace(_tplNumber) || _selectedAccountId is null) return;

        _isLoading = true;
        _paymentSuccess = false;
        _errorMessage = "";

        try
        {
            var fullAccountNumber = ComposeAccountNumber(_tplPrefix, _tplNumber, _tplBankCode);
            await Api.CreatePaymentTemplateAsync(
                _selectedAccountId.Value, _tplName.Trim(), fullAccountNumber, _selectedAccountCurrency,
                string.IsNullOrWhiteSpace(_tplRecipientName) ? null : _tplRecipientName.Trim(),
                _tplAmount > 0 ? _tplAmount : null,
                string.IsNullOrWhiteSpace(_tplDescription) ? null : _tplDescription);
            _paymentSuccess = true;
            _tplName = "";
            _tplPrefix = "";
            _tplNumber = "";
            _tplRecipientName = "";
            _tplAmount = null;
            _tplDescription = "";
            await LoadData();
        }
        catch
        {
            _errorMessage = "Uložení šablony se nezdařilo.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DeleteTemplate(Guid id)
    {
        try
        {
            await Api.DeletePaymentTemplateAsync(id);
            await LoadData();
        }
        catch
        {
            _errorMessage = "Smazání šablony se nezdařilo.";
        }
    }

    private async Task SendInternationalPayment()
    {
        if (!IsIntlFormValid() || _selectedAccountId is null) return;

        _isLoading = true;
        _errorMessage = "";
        _paymentSuccess = false;

        try
        {
            var ibanClean = _intlIban.Replace(" ", "").ToUpper();
            var desc = $"[INTL {_intlChargeType}] {_intlBeneficiary} | SWIFT: {_intlSwift.ToUpper()} | {_intlDescription}";
            await Api.SendPaymentAsync(_selectedAccountId.Value, ibanClean, _intlAmount, _intlCurrency, desc);
            _paymentSuccess = true;
            _intlIban = "";
            _intlSwift = "";
            _intlBeneficiary = "";
            _intlBeneficiaryAddress = "";
            _intlAmount = 0;
            _intlDescription = "";
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message.Contains("Insufficient") ? "Nedostatek prostředků na účtu." : "Zahraniční platba se nezdařila. Zkuste to znovu.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void UseTemplate(PaymentTemplateDto tpl)
    {
        _activeTab = "payment";
        _pageView = "menu";
        ParseAccountNumberToFields(tpl.RecipientAccountNumber, out var pfx, out var num, out var bank);
        _recipientPrefix = pfx;
        _recipientNumber = num;
        _recipientBankCode = bank;
        _description = tpl.DefaultDescription ?? "";
        _amount = tpl.DefaultAmount ?? 0;
        _errorMessage = "";
        _paymentSuccess = false;
    }

    private void OnTemplateSelected(ChangeEventArgs e)
    {
        var tplId = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(tplId)) return;
        var tpl = _templates.FirstOrDefault(t => t.Id.ToString() == tplId);
        if (tpl is null) return;
        ParseAccountNumberToFields(tpl.RecipientAccountNumber, out var pfx, out var num, out var bank);
        _recipientPrefix = pfx;
        _recipientNumber = num;
        _recipientBankCode = bank;
        _description = tpl.DefaultDescription ?? "";
        _amount = tpl.DefaultAmount ?? 0;
    }

    private static string FormatInterval(string interval) => interval switch
    {
        "Daily" => "denně",
        "Weekly" => "týdně",
        "Monthly" => "měsíčně",
        "Quarterly" => "čtvrtletně",
        "Yearly" => "ročně",
        _ => interval
    };

    private sealed record ContactVm(string Name, string Initials, string AccountNumber);
    private sealed record BankCodeEntry(string Code, string Name);
}
