@page "/sporeni"
@namespace FairBank.Web.Savings.Pages
@inject IFairBankApi Api
@inject IAuthService Auth

<PageHeader Title="FINANČNÍ VÝZVY A CÍLE" ShowChip="false">
    <Actions>
        <VbButton Variant="outline" Size="sm" IconName="plus" OnClick="@(() => _showNewGoalForm = true)">Nový cíl</VbButton>
        <VbButton Variant="outline" Size="sm" IconName="plus" OnClick="@(() => _showNewRuleForm = true)">Nové pravidlo</VbButton>
    </Actions>
</PageHeader>

<div class="page-content savings-page">

    @if (_loading)
    {
        <ContentCard>
            <ChildContent>
                <div class="savings-loading">
                    <VbIcon Name="target" Size="md" Color="var(--vb-text-muted)" />
                    <span style="color:var(--vb-text-muted);margin-top:8px;">Načítám spoření...</span>
                </div>
            </ChildContent>
        </ContentCard>
    }
    else if (_error is not null)
    {
        <ContentCard>
            <ChildContent>
                <div class="savings-loading">
                    <VbIcon Name="warning" Size="sm" Color="var(--vb-red)" />
                    <span style="color:var(--vb-red);margin-top:4px;">@_error</span>
                </div>
            </ChildContent>
        </ContentCard>
    }
    else
    {
        @* ── Savings Account Status Card ── *@
        @if (_savingsAccount is not null)
        {
            <ContentCard Title="SPŘICÍ ÚČET" CssClass="section-savings-account">
                <Icon><VbIcon Name="target" Size="sm" Color="var(--vb-gold)" /></Icon>
                <ChildContent>
                    <div class="savings-account-header">
                        <div class="savings-account-balance">
                            <span class="savings-balance-label">Zůstatek</span>
                            <span class="savings-balance-amount">@_savingsAccount.Balance.ToString("N0") Kč</span>
                        </div>
                        <div class="savings-account-badge">
                            <VbIcon Name="check" Size="xs" Color="var(--vb-green)" />
                            <span>Aktivní</span>
                        </div>
                    </div>
                    <div class="savings-account-number">@_savingsAccount.AccountNumber</div>
                </ChildContent>
            </ContentCard>
        }
        else
        {
            <ContentCard Title="SPOŘICÍ ÚČET" CssClass="section-savings-account">
                <Icon><VbIcon Name="target" Size="sm" Color="var(--vb-text-muted)" /></Icon>
                <ChildContent>
                    <div class="savings-request-block">
                        <div class="savings-request-info">
                            <VbIcon Name="warning" Size="sm" Color="var(--vb-gold)" />
                            <div>
                                <span class="savings-request-title">Nemáte aktivní spořicí účet</span>
                                <span class="savings-request-desc">Zažádejte o spořicí účet. Vaše žádost bude odeslána bankéři ke schválení.</span>
                            </div>
                        </div>
                        @if (_requestSuccess)
                        {
                            <div class="success-banner"><VbIcon Name="check" Size="xs" /> Žádost úspěšně odeslána! Účet byl založen.</div>
                        }
                        else
                        {
                            <VbButton Variant="primary" FullWidth="true" OnClick="RequestSavingsAccount" Disabled="@_requestLoading">
                                @(_requestLoading ? "Vytvářím účet..." : "Zažádat o spořicí účet")
                            </VbButton>
                            @if (!string.IsNullOrEmpty(_requestError))
                            {
                                <div class="error-banner">@_requestError</div>
                            }
                        }
                    </div>
                </ChildContent>
            </ContentCard>
        }

        @* ── New Goal Form ── *@
        @if (_showNewGoalForm)
        {
            <ContentCard Title="Nový spořicí cíl" CssClass="section-new-goal">
                <Icon><VbIcon Name="plus" Size="sm" Color="var(--vb-gold)" /></Icon>
                <ChildContent>
                    <div class="new-goal-form">
                        <div class="form-group">
                            <label class="form-label">Název</label>
                            <input class="form-input" @bind="_newGoalName" placeholder="Dovolená, Nové auto..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Popis (volitelný)</label>
                            <input class="form-input" @bind="_newGoalDescription" placeholder="Popis cíle..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Cílová částka</label>
                            <input class="form-input" type="number" min="1" @bind="_newGoalTargetAmount" placeholder="50000" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Měna</label>
                            <select class="form-input" @bind="_newGoalCurrency">
                                <option value="CZK">CZK</option>
                                <option value="EUR">EUR</option>
                                <option value="USD">USD</option>
                            </select>
                        </div>
                        @if (!string.IsNullOrEmpty(_formError))
                        {
                            <div class="field-error">@_formError</div>
                        }
                        <div class="form-actions">
                            <VbButton Variant="primary" OnClick="CreateGoal" Disabled="@_saving">
                                @(_saving ? "Vytvářím..." : "Vytvořit cíl")
                            </VbButton>
                            <VbButton Variant="ghost" OnClick="@(() => { _showNewGoalForm = false; _formError = ""; })">Zrušit</VbButton>
                        </div>
                    </div>
                </ChildContent>
            </ContentCard>
        }

        @* ── New Rule Form ── *@
        @if (_showNewRuleForm)
        {
            <ContentCard Title="Nové pravidlo spoření" CssClass="section-new-rule">
                <Icon><VbIcon Name="plus" Size="sm" Color="var(--vb-gold)" /></Icon>
                <ChildContent>
                    <div class="new-goal-form">
                        <div class="form-group">
                            <label class="form-label">Název</label>
                            <input class="form-input" @bind="_newRuleName" placeholder="Týdenní spoření..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Popis (volitelný)</label>
                            <input class="form-input" @bind="_newRuleDescription" placeholder="Popis pravidla..." />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Typ</label>
                            <select class="form-input" @bind="_newRuleType">
                                <option value="RoundUp">Zaokrouhlování</option>
                                <option value="Weekly">Týdenní</option>
                                <option value="Monthly">Měsíční</option>
                                <option value="Percentage">Procento</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Částka</label>
                            <input class="form-input" type="number" min="1" @bind="_newRuleAmount" placeholder="500" />
                        </div>
                        @if (!string.IsNullOrEmpty(_formError))
                        {
                            <div class="field-error">@_formError</div>
                        }
                        <div class="form-actions">
                            <VbButton Variant="primary" OnClick="CreateRule" Disabled="@_saving">
                                @(_saving ? "Vytvářím..." : "Vytvořit pravidlo")
                            </VbButton>
                            <VbButton Variant="ghost" OnClick="@(() => { _showNewRuleForm = false; _formError = ""; })">Zrušit</VbButton>
                        </div>
                    </div>
                </ChildContent>
            </ContentCard>
        }

        @* ── Savings Goals with poker-chip milestones ── *@
        @if (_goals.Any())
        {
            @foreach (var goal in _goals)
            {
                var milestones = GenerateMilestones(goal);
                var icon = goal.ProgressPercent >= 100 ? "trophy" : goal.ProgressPercent >= 50 ? "star" : "target";
                <ContentCard Title="@goal.Name" CssClass="section-goal">
                    <Icon><VbIcon Name="@icon" Size="sm" Color="var(--vb-gold)" /></Icon>
                    <ChildContent>
                        <div class="goal-card-content">
                            <div class="goal-header-row">
                                <span class="goal-progress-label">@(goal.Description ?? "Spořicí cíl")</span>
                                <span class="goal-percentage @(goal.ProgressPercent >= 75 ? "positive" : "")">@goal.ProgressPercent%</span>
                            </div>
                            <div class="chips-row">
                                @foreach (var milestone in milestones)
                                {
                                    <div class="milestone">
                                        <PokerChip Value="@milestone.Label" IsActive="@milestone.IsReached" Size="sm" />
                                    </div>
                                }
                            </div>
                            <div class="progress-bar-track">
                                <div class="progress-bar-fill" style="width: @(Math.Min(100, goal.ProgressPercent))%"></div>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Naspořeno</span>
                                <span class="stat-value">@goal.CurrentAmount.ToString("N0") @goal.Currency</span>
                            </div>
                            <div class="stat-row">
                                <span class="stat-label">Cíl</span>
                                <span class="stat-value">@goal.TargetAmount.ToString("N0") @goal.Currency</span>
                            </div>

                            @* ── Deposit / Withdraw ── *@
                            @if (!goal.IsCompleted)
                            {
                                <div class="goal-actions">
                                    @if (_depositGoalId == goal.Id)
                                    {
                                        <div class="goal-action-form">
                                            <input class="form-input amount-input" type="number" min="1" @bind="_depositAmount" placeholder="Částka" />
                                            <VbButton Variant="primary" Size="sm" OnClick="@(() => DepositToGoal(goal.Id))" Disabled="@_saving">
                                                @(_saving ? "..." : "Potvrdit")
                                            </VbButton>
                                            <VbButton Variant="ghost" Size="sm" OnClick="@(() => _depositGoalId = null)">Zrušit</VbButton>
                                        </div>
                                    }
                                    else if (_withdrawGoalId == goal.Id)
                                    {
                                        <div class="goal-action-form">
                                            <input class="form-input amount-input" type="number" min="1" @bind="_withdrawAmount" placeholder="Částka" />
                                            <VbButton Variant="primary" Size="sm" OnClick="@(() => WithdrawFromGoal(goal.Id))" Disabled="@_saving">
                                                @(_saving ? "..." : "Potvrdit")
                                            </VbButton>
                                            <VbButton Variant="ghost" Size="sm" OnClick="@(() => _withdrawGoalId = null)">Zrušit</VbButton>
                                        </div>
                                    }
                                    else
                                    {
                                        <VbButton Variant="primary" Size="sm" IconName="plus" OnClick="@(() => { _depositGoalId = goal.Id; _depositAmount = 0; })">Vložit</VbButton>
                                        <VbButton Variant="outline" Size="sm" IconName="arrow-down" OnClick="@(() => { _withdrawGoalId = goal.Id; _withdrawAmount = 0; })">Vybrat</VbButton>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="goal-completed-badge">
                                    <VbIcon Name="check" Size="xs" Color="var(--vb-green)" />
                                    <span>Cíl splněn!</span>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(_goalActionError) && (_depositGoalId == goal.Id || _withdrawGoalId == goal.Id))
                            {
                                <div class="field-error">@_goalActionError</div>
                            }
                        </div>
                    </ChildContent>
                </ContentCard>
            }
        }
        else
        {
            <ContentCard>
                <ChildContent>
                    <div class="savings-empty">
                        <PokerChip Value="?" Size="lg" />
                        <span class="empty-title">Zatím nemáte žádné spořicí cíle</span>
                        <span class="empty-desc">Vytvořte si svůj první spořicí cíl a začněte šetřit na to, co opravdu chcete.</span>
                        <VbButton Variant="outline" IconName="plus" OnClick="@(() => _showNewGoalForm = true)">Vytvořit první cíl</VbButton>
                    </div>
                </ChildContent>
            </ContentCard>
        }

        @* ── Savings Rules ── *@
        <ContentCard Title="Pravidla spoření">
            <Icon><VbIcon Name="settings" Size="sm" Color="var(--vb-red)" /></Icon>
            <ChildContent>
                <p class="rule-description">
                    Nastavte si vlastní pravidla automatického spoření.
                </p>
                @if (_rules.Any())
                {
                    @foreach (var rule in _rules)
                    {
                        <div class="savings-rule">
                            <ToggleSwitch Label="@rule.Name" IsOn="@rule.IsEnabled" IsOnChanged="@(_ => ToggleRule(rule.Id))" />
                            <span class="rule-desc">@(rule.Description ?? GetRuleTypeLabel(rule.Type))</span>
                            <span class="rule-amount">@rule.Amount.ToString("N0") Kč</span>
                        </div>
                    }
                }
                else
                {
                    <div class="rules-empty">
                        <span class="empty-text">Zatím nemáte žádná pravidla spoření.</span>
                    </div>
                }
            </ChildContent>
        </ContentCard>

        @* ── Tip Card ── *@
        <div class="tip-card">
            <div class="tip-icon"><VbIcon Name="fire" Size="sm" /></div>
            <div class="tip-content">
                <span class="tip-title">Tip pro spoření</span>
                <span class="tip-text">Pravidlo 50/30/20: 50% příjmů na potřeby, 30% na přání, 20% na spoření a investice.</span>
            </div>
        </div>
    }
</div>

<style>
    .savings-loading, .savings-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 32px 16px;
        gap: 8px;
        text-align: center;
    }

    .empty-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--vb-text-primary);
        margin-top: 8px;
    }

    .empty-desc {
        font-size: 0.85rem;
        color: var(--vb-text-muted);
        max-width: 280px;
        margin-bottom: 12px;
    }

    .rules-empty {
        padding: 12px 0;
    }

    .empty-text {
        font-size: 0.85rem;
        color: var(--vb-text-muted);
    }

    .new-goal-form {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .form-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--vb-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-input {
        padding: 10px 14px;
        border: 1px solid var(--vb-input-border);
        border-radius: var(--vb-radius-sm);
        background: var(--vb-input-bg);
        color: var(--vb-text-primary);
        font-size: 0.95rem;
        font-family: var(--vb-font);
        transition: border-color var(--vb-transition);
    }

    .form-input:focus {
        outline: none;
        border-color: var(--vb-gold);
        box-shadow: 0 0 0 2px rgba(212, 168, 67, 0.15);
    }

    .form-actions {
        display: flex;
        gap: 8px;
        margin-top: 4px;
    }

    .field-error {
        font-size: 0.8rem;
        color: var(--vb-red);
    }

    .goal-actions {
        display: flex;
        gap: 8px;
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--vb-divider);
    }

    .goal-action-form {
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
    }

    .amount-input {
        width: 120px;
        padding: 6px 10px;
    }

    .goal-completed-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 12px;
        padding: 8px 12px;
        background: rgba(39, 174, 96, 0.08);
        border-radius: var(--vb-radius-sm);
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--vb-green);
    }

    .rule-amount {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--vb-text-primary);
        margin-left: auto;
    }

    .savings-account-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 6px;
    }

    .savings-account-balance {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .savings-balance-label {
        font-size: 0.75rem;
        color: var(--vb-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .savings-balance-amount {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--vb-text-primary);
    }

    .savings-account-badge {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        background: rgba(39, 174, 96, 0.1);
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--vb-green);
    }

    .savings-account-number {
        font-size: 0.78rem;
        color: var(--vb-text-muted);
        font-family: monospace;
        margin-top: 4px;
    }

    .savings-request-block {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .savings-request-info {
        display: flex;
        gap: 10px;
        align-items: flex-start;
    }

    .savings-request-title {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--vb-text-primary);
        margin-bottom: 3px;
    }

    .savings-request-desc {
        display: block;
        font-size: 0.8rem;
        color: var(--vb-text-muted);
    }

    .success-banner {
        padding: 10px 14px;
        background: rgba(39, 174, 96, 0.1);
        border-radius: var(--vb-radius-sm);
