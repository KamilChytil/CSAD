        align-items: center;
        gap: 6px;
    }

    .error-banner {
        padding: 10px 14px;
        background: rgba(210, 63, 58, 0.08);
        border-radius: var(--vb-radius-sm);
        color: var(--vb-red);
        font-size: 0.85rem;
    }
    }
</style>

@code {
    private AuthSession? _session;
    private Guid? _accountId;
    private FairBank.Web.Shared.Models.AccountResponse? _savingsAccount;

    private bool _loading = true;
    private string? _error;
    private string _formError = "";
    private bool _saving;

    // Savings account request
    private bool _requestLoading;
    private bool _requestSuccess;
    private string _requestError = "";

    private List<SavingsGoalDto> _goals = [];
    private List<SavingsRuleDto> _rules = [];

    // New goal form
    private bool _showNewGoalForm;
    private string _newGoalName = "";
    private string _newGoalDescription = "";
    private decimal _newGoalTargetAmount;
    private string _newGoalCurrency = "CZK";

    // New rule form
    private bool _showNewRuleForm;
    private string _newRuleName = "";
    private string _newRuleDescription = "";
    private string _newRuleType = "RoundUp";
    private decimal _newRuleAmount;

    // Goal deposit/withdraw
    private Guid? _depositGoalId;
    private Guid? _withdrawGoalId;
    private decimal _depositAmount;
    private decimal _withdrawAmount;
    private string _goalActionError = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _session = Auth.CurrentSession;
            if (_session is null)
            {
                _error = "Nejste přihlášeni.";
                _loading = false;
                return;
            }

            var accounts = await Api.GetAccountsByOwnerAsync(_session.UserId);
            if (accounts.Any())
            {
                _savingsAccount = accounts.FirstOrDefault(a => a.AccountType == "Savings");
                // Goals and rules belong to the savings account if it exists, otherwise checking
                var primaryAccount = _savingsAccount ?? accounts.FirstOrDefault(a => a.AccountType == "Checking") ?? accounts[0];
                _accountId = primaryAccount.Id;
                await LoadData();
            }
            else
            {
                _goals = [];
                _rules = [];
            }
        }
        catch (Exception ex)
        {
            _error = $"Chyba při načítání: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadData()
    {
        if (_accountId is null) return;
        try
        {
            var goalsTask = Api.GetSavingsGoalsByAccountAsync(_accountId.Value);
            var rulesTask = Api.GetSavingsRulesByAccountAsync(_accountId.Value);
            await Task.WhenAll(goalsTask, rulesTask);
            _goals = goalsTask.Result;
            _rules = rulesTask.Result;
        }
        catch (Exception ex)
        {
            _error = $"Chyba při načítání dat: {ex.Message}";
        }
    }

    private async Task RequestSavingsAccount()
    {
        if (_session is null) return;
        _requestLoading = true;
        _requestError = "";
        try
        {
            var acc = await Api.CreateSavingsAccountAsync(_session.UserId);
            _savingsAccount = acc;
            _accountId = acc.Id;
            _requestSuccess = true;
            await LoadData();
        }
        catch (Exception ex)
        {
            _requestError = $"Chyba: {ex.Message}";
        }
        finally
        {
            _requestLoading = false;
        }
    }

    private async Task CreateGoal()
    {
        if (_accountId is null) return;
        if (string.IsNullOrWhiteSpace(_newGoalName))
        {
            _formError = "Zadejte název cíle.";
            return;
        }
        if (_newGoalTargetAmount <= 0)
        {
            _formError = "Zadejte cílovou částku.";
            return;
        }

        _saving = true;
        _formError = "";
        try
        {
            await Api.CreateSavingsGoalAsync(
                _accountId.Value,
                _newGoalName.Trim(),
                string.IsNullOrWhiteSpace(_newGoalDescription) ? null : _newGoalDescription.Trim(),
                _newGoalTargetAmount,
                _newGoalCurrency);

            _showNewGoalForm = false;
            _newGoalName = "";
            _newGoalDescription = "";
            _newGoalTargetAmount = 0;
            _newGoalCurrency = "CZK";
            await LoadData();
        }
        catch (Exception ex)
        {
            _formError = $"Chyba: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task CreateRule()
    {
        if (_accountId is null) return;
        if (string.IsNullOrWhiteSpace(_newRuleName))
        {
            _formError = "Zadejte název pravidla.";
            return;
        }
        if (_newRuleAmount <= 0)
        {
            _formError = "Zadejte částku.";
            return;
        }

        _saving = true;
        _formError = "";
        try
        {
            await Api.CreateSavingsRuleAsync(
                _accountId.Value,
                _newRuleName.Trim(),
                string.IsNullOrWhiteSpace(_newRuleDescription) ? null : _newRuleDescription.Trim(),
                _newRuleType,
                _newRuleAmount);

            _showNewRuleForm = false;
            _newRuleName = "";
            _newRuleDescription = "";
            _newRuleType = "RoundUp";
            _newRuleAmount = 0;
            await LoadData();
        }
        catch (Exception ex)
        {
            _formError = $"Chyba: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ToggleRule(Guid ruleId)
    {
        try
        {
            await Api.ToggleSavingsRuleAsync(ruleId);
            await LoadData();
        }
        catch (Exception ex)
        {
            _error = $"Chyba: {ex.Message}";
        }
    }

    private async Task DepositToGoal(Guid goalId)
    {
        if (_depositAmount <= 0)
        {
            _goalActionError = "Zadejte částku.";
            return;
        }

        _saving = true;
        _goalActionError = "";
        try
        {
            await Api.DepositToSavingsGoalAsync(goalId, _depositAmount);
            _depositGoalId = null;
            _depositAmount = 0;
            await LoadData();
        }
        catch (Exception ex)
        {
            _goalActionError = $"Chyba: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task WithdrawFromGoal(Guid goalId)
    {
        if (_withdrawAmount <= 0)
        {
            _goalActionError = "Zadejte částku.";
            return;
        }

        _saving = true;
        _goalActionError = "";
        try
        {
            await Api.WithdrawFromSavingsGoalAsync(goalId, _withdrawAmount);
            _withdrawGoalId = null;
            _withdrawAmount = 0;
            await LoadData();
        }
        catch (Exception ex)
        {
            _goalActionError = $"Chyba: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private static List<MilestoneVm> GenerateMilestones(SavingsGoalDto goal)
    {
        var milestones = new List<MilestoneVm>();
        var target = goal.TargetAmount;
        if (target <= 0) return milestones;

        var steps = new[] { 0.25m, 0.50m, 0.75m, 1.0m };
        foreach (var step in steps)
        {
            var stepAmount = target * step;
            var label = stepAmount >= 1_000_000
                ? $"{stepAmount / 1_000_000:0.#}M"
                : stepAmount >= 1_000
                    ? $"{stepAmount / 1_000:0.#}k"
                    : $"{stepAmount:0}";
            var isReached = goal.CurrentAmount >= stepAmount;

            if (step == 1.0m)
                milestones.Add(new MilestoneVm("Va-bank", isReached));
            else
                milestones.Add(new MilestoneVm(label, isReached));
        }

        return milestones;
    }

    private static string GetRuleTypeLabel(string type) => type switch
    {
        "RoundUp" => "Zaokrouhlování plateb",
        "Weekly" => "Týdenní spoření",
        "Monthly" => "Měsíční spoření",
        "Percentage" => "Procentuální spoření",
        _ => type
    };

    private sealed record MilestoneVm(string Label, bool IsReached);
}
