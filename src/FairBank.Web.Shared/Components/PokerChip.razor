@namespace FairBank.Web.Shared.Components
@inject ThemeService Theme
@implements IDisposable

<div class="poker-chip @SizeClass @(IsActive ? "active" : "")">
    <div class="chip-img-wrap">
        <img src="@ChipPath" alt="" class="chip-img" />
        @if (!string.IsNullOrEmpty(Value))
        {
            <span class="chip-value">@Value</span>
        }
    </div>
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public bool IsActive { get; set; }
    [Parameter] public string Size { get; set; } = "md";

    private string SizeClass => Size switch
    {
        "sm" => "chip-sm",
        "lg" => "chip-lg",
        _ => "chip-md"
    };

    private string ChipPath => Theme.IsDarkMode ? "icons/chip_dark.png" : "icons/chip_light.png";

    protected override void OnInitialized() => Theme.OnThemeChanged += HandleThemeChanged;
    private void HandleThemeChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Theme.OnThemeChanged -= HandleThemeChanged;
}
