                break;
            case "trophy":
                <polyline points="6 9 6 3 18 3 18 9" />
                <path d="M6 18H5a3 3 0 0 1-3-3 3 3 0 0 1 3-3h1" />
                <path d="M18 18h1a3 3 0 0 0 3-3 3 3 0 0 0-3-3h-1" />
                <path d="M6 9a6 6 0 0 0 12 0" />
                <line x1="9" y1="21" x2="15" y2="21" />
                <line x1="12" y1="15" x2="12" y2="21" />
