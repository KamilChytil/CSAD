            case "rocket":
                <path d="M4.5 16.5c-1.5 1.5-1.8 3-1.5 3.5s2 0 3.5-1.5l-2-2z" />
                <path d="M12 2S7 7 7 13l4 4c6 0 11-5 11-11L12 2z" />
                <circle cx="15" cy="9" r="1.5" fill="currentColor" stroke="none" />
                <path d="M7 13l-3 3" />
