        "dice" => """<svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="3" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="8" cy="8" r="1.5" fill="currentColor"/><circle cx="16" cy="8" r="1.5" fill="currentColor"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/><circle cx="8" cy="16" r="1.5" fill="currentColor"/><circle cx="16" cy="16" r="1.5" fill="currentColor"/></svg>""",

        "crown" => """<svg viewBox="0 0 24 24"><path d="M2 20h20M4 16l2-12 6 6 6-6 2 12z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>""",

        "fire" => """<svg viewBox="0 0 24 24"><path d="M12 23c-4.97 0-9-3.58-9-8 0-5.5 4-10 9-14 5 4 9 8.5 9 14 0 4.42-4.03 8-9 8z" fill="none" stroke="currentColor" stroke-width="2"/><path d="M12 23c-2.21 0-4-1.79-4-4 0-2.75 2-5 4-7 2 2 4 4.25 4 7 0 2.21-1.79 4-4 4z" fill="none" stroke="currentColor" stroke-width="2"/></svg>""",

