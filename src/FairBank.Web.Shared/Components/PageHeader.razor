@namespace FairBank.Web.Shared.Components
@inject ThemeService Theme
@implements IDisposable

<header class="page-header">
    @if (ShowChip)
    {
        <div class="header-chip">
            <img src="@ChipPath" alt="" class="header-chip-img" />
        </div>
    }
    <div class="header-content">
        <h1 class="header-title">@Title</h1>
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <span class="header-subtitle">@Subtitle</span>
        }
    </div>
    @if (Actions is not null)
    {
        <div class="header-actions">
            @Actions
        </div>
    }
</header>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public bool ShowChip { get; set; } = true;
    [Parameter] public RenderFragment? Actions { get; set; }

    private string ChipPath => Theme.IsDarkMode ? "icons/chip_dark.png" : "icons/chip_light.png";

    protected override void OnInitialized() => Theme.OnThemeChanged += HandleThemeChanged;
    private void HandleThemeChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Theme.OnThemeChanged -= HandleThemeChanged;
}
