@using Microsoft.AspNetCore.Components.Routing
@inject IAuthService Auth
@inject ThemeService Theme
@implements IDisposable

<nav class="side-nav">
    <div class="side-nav-brand">
        <div class="side-nav-chip">
            <div class="chip-outer">
                <div class="chip-inner">V</div>
            </div>
        </div>
        <span class="side-nav-title">Va-bank</span>
    </div>

    <div class="side-nav-links">
        <NavLink class="side-nav-item" href="prehled" Match="NavLinkMatch.All">
            <span class="side-nav-icon"><VbIcon Name="home" Size="sm" /></span>
            <span class="side-nav-label">Přehled</span>
        </NavLink>
        <NavLink class="side-nav-item" href="platby">
            <span class="side-nav-icon"><VbIcon Name="payments" Size="sm" /></span>
            <span class="side-nav-label">Platby</span>
        </NavLink>
        <NavLink class="side-nav-item" href="sporeni">
            <span class="side-nav-icon"><VbIcon Name="target" Size="sm" /></span>
            <span class="side-nav-label">Spoření</span>
        </NavLink>
        <NavLink class="side-nav-item" href="investice">
            <span class="side-nav-icon"><VbIcon Name="investments" Size="sm" /></span>
            <span class="side-nav-label">Investice</span>
        </NavLink>
        <NavLink class="side-nav-item" href="kurzy">
            <span class="side-nav-icon">💱</span>
            <span class="side-nav-label">Kurzy</span>
        </NavLink>
        @if (Auth.CurrentSession?.Role != "Child")
        {
            <NavLink class="side-nav-item" href="produkty">
                <span class="side-nav-icon"><VbIcon Name="bank" Size="sm" /></span>
                <span class="side-nav-label">Produkty</span>
            </NavLink>
        }
        <NavLink class="side-nav-item" href="zpravy">
            <span class="side-nav-icon"><VbIcon Name="chat" Size="sm" /></span>
            <span class="side-nav-label">Zprávy</span>
        </NavLink>
        @if (Auth.CurrentSession?.Role == "Banker")
        {
            <NavLink class="side-nav-item" href="sprava">
                <span class="side-nav-icon"><VbIcon Name="clipboard" Size="sm" /></span>
                <span class="side-nav-label">Správa</span>
            </NavLink>
        }
        @if (Auth.CurrentSession?.Role == "Admin")
        {
            <NavLink class="side-nav-item" href="admin">
                <span class="side-nav-icon"><VbIcon Name="settings" Size="sm" /></span>
                <span class="side-nav-label">Admin</span>
            </NavLink>
        }
        <NavLink class="side-nav-item" href="profil">
            <span class="side-nav-icon"><VbIcon Name="user" Size="sm" /></span>
            <span class="side-nav-label">Profil</span>
        </NavLink>
    </div>

    <div class="side-nav-footer">
        <button class="side-nav-theme-btn" @onclick="ToggleTheme">
            <VbIcon Name="@(Theme.IsDarkMode ? "sun" : "moon")" Size="sm" />
            <span>@(Theme.IsDarkMode ? "Světlý" : "Tmavý") režim</span>
        </button>
        <span class="side-nav-tagline">Jediná banka na kterou můžete vsadit.</span>
    </div>
</nav>

@code {
    protected override void OnInitialized()
    {
        Auth.AuthStateChanged += HandleAuthChanged;
        Theme.OnThemeChanged += HandleAuthChanged;
    }

    private async Task ToggleTheme() => await Theme.ToggleAsync();

    private void HandleAuthChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Auth.AuthStateChanged -= HandleAuthChanged;
        Theme.OnThemeChanged -= HandleAuthChanged;
    }
}
