@using Microsoft.AspNetCore.Components.Routing
@inject AuthStateService Auth
@inject IAuthService AuthSvc
@implements IDisposable

<nav class="bottom-nav">
    <NavLink class="nav-item" href="prehled" Match="NavLinkMatch.All">
        <span class="nav-icon">🏠</span>
        <span class="nav-label">Přehled</span>
    </NavLink>
    <NavLink class="nav-item" href="platby">
        <span class="nav-icon">💳</span>
        <span class="nav-label">Platby</span>
    </NavLink>
    <NavLink class="nav-item" href="sporeni">
        <span class="nav-icon">🎯</span>
        <span class="nav-label">Spoření</span>
    </NavLink>
    <NavLink class="nav-item" href="investice">
        <span class="nav-icon">📈</span>
        <span class="nav-label">Investice</span>
    </NavLink>
    <NavLink class="nav-item" href="@GetChatUrl()">
        <span class="nav-icon">💬</span>
        <span class="nav-label">Zprávy</span>
    </NavLink>
    @if (Auth.IsAdmin)
    {
        <NavLink class="nav-item" href="admin">
            <span class="nav-icon">⚙️</span>
            <span class="nav-label">Admin</span>
        </NavLink>
    }
    else
    {
        <NavLink class="nav-item" href="profil">
            <span class="nav-icon">👤</span>
            <span class="nav-label">Profil</span>
        </NavLink>
    }
</nav>

@code {
    protected override void OnInitialized()
    {
        Auth.OnChanged += HandleAuthChanged;
    }

    private void HandleAuthChanged() => InvokeAsync(StateHasChanged);

    private string GetChatUrl()
    {
        var session = AuthSvc.CurrentSession;
        if (session == null) return "prehled";
        
        // Banker sees Client, Client sees Banker
        return session.UserId == Guid.Parse("b0000000-0000-0000-0000-000000000001")
            ? "chat/c0000000-0000-0000-0000-000000000001"
            : "chat/b0000000-0000-0000-0000-000000000001";
    }

    public void Dispose()
    {
        Auth.OnChanged -= HandleAuthChanged;
    }
}
