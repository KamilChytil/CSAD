@using Microsoft.AspNetCore.Components.Routing
@inject AuthStateService Auth
@implements IDisposable

<nav class="bottom-nav">
    <NavLink class="nav-item" href="prehled" Match="NavLinkMatch.All">
        <span class="nav-icon"><VbIcon Name="home" Size="sm" /></span>
        <span class="nav-label">Přehled</span>
    </NavLink>
    <NavLink class="nav-item" href="platby">
        <span class="nav-icon"><VbIcon Name="payments" Size="sm" /></span>
        <span class="nav-label">Platby</span>
    </NavLink>
    <NavLink class="nav-item" href="sporeni">
        <span class="nav-icon"><VbIcon Name="target" Size="sm" /></span>
        <span class="nav-label">Spoření</span>
    </NavLink>
    <NavLink class="nav-item" href="investice">
        <span class="nav-icon"><VbIcon Name="investments" Size="sm" /></span>
        <span class="nav-label">Investice</span>
    </NavLink>
    <NavLink class="nav-item" href="kurzy">
        <span class="nav-icon">💱</span>
        <span class="nav-label">Kurzy</span>
    </NavLink>
    <NavLink class="nav-item" href="profil">
        <span class="nav-icon"><VbIcon Name="user" Size="sm" /></span>
        <span class="nav-label">Profil</span>
    </NavLink>
</nav>

@code {
    protected override void OnInitialized()
    {
        Auth.OnChanged += HandleAuthChanged;
    }

    private void HandleAuthChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Auth.OnChanged -= HandleAuthChanged;
    }
}
