@page "/deti"
@using FairBank.Web.Shared.Models
@using FairBank.Web.Shared.Services
@inject IFairBankApi Api
@inject IAuthService Auth
@inject NavigationManager Navigation

<PageHeader Title="DETI" ShowChip="false">
    <Actions>
        <VbButton Variant="primary" Size="sm" IconName="plus" OnClick="OpenAddModal">Pridat dite</VbButton>
    </Actions>
</PageHeader>

<div class="page-content children-page">
    @if (_loading)
    {
        <div class="children-empty">Nacitani...</div>
    }
    else if (!_children.Any())
    {
        <div class="children-empty">
            <div class="empty-icon"><VbIcon Name="users" Size="sm" /></div>
            <p>Zatim zadne deti.</p>
            <VbButton Variant="primary" IconName="plus" OnClick="OpenAddModal">Pridat dite</VbButton>
        </div>
    }
    else
    {
        <div class="children-grid">
            @foreach (var child in _children)
            {
                <div class="child-card" @onclick="() => GoToChild(child.Id)">
                    <div class="child-avatar">
                        <VbIcon Name="user" Size="sm" />
                    </div>
                    <div class="child-info">
                        <div class="child-name">@child.FirstName @child.LastName</div>
                        <div class="child-email">@child.Email</div>
                    </div>
                    <div class="child-arrow">
                        <VbIcon Name="chevron-right" Size="sm" />
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_showAddModal)
{
    <div class="modal-overlay" @onclick="CloseAddModal">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>Pridat dite</h3>
                <button class="modal-close" @onclick="CloseAddModal">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="form-error">@_error</div>
                }
                <div class="form-group">
                    <label>Jmeno</label>
                    <input type="text" @bind="_firstName" placeholder="Jmeno" class="form-input" />
                </div>
                <div class="form-group">
                    <label>Prijmeni</label>
                    <input type="text" @bind="_lastName" placeholder="Prijmeni" class="form-input" />
                </div>
                <div class="form-group">
                    <label>E-mail</label>
                    <input type="email" @bind="_email" placeholder="email@example.com" class="form-input" />
                </div>
                <div class="form-group">
                    <label>Heslo</label>
                    <input type="password" @bind="_password" placeholder="Heslo" class="form-input" />
                </div>
            </div>
            <div class="modal-footer">
                <VbButton Variant="ghost" OnClick="CloseAddModal">Zrusit</VbButton>
                <VbButton Variant="primary" OnClick="CreateChild" Disabled="_creating">
                    @(_creating ? "Vytvarim..." : "Vytvorit")
                </VbButton>
            </div>
        </div>
    </div>
}

<style>
    .children-page {
        max-width: 640px;
        margin: 0 auto;
        padding: 1rem;
    }

    .children-empty {
        text-align: center;
        color: var(--vb-text-muted);
        margin-top: 3rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .empty-icon {
        font-size: 3rem;
        opacity: 0.3;
    }

    .children-grid {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .child-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: var(--vb-bg-elevated);
        border: 1px solid var(--vb-card-border);
        border-radius: var(--vb-radius-md);
        box-shadow: var(--vb-shadow-xs);
        cursor: pointer;
        transition: var(--vb-transition);
    }

    .child-card:hover {
        box-shadow: var(--vb-shadow);
        transform: translateY(-1px);
        border-color: var(--vb-red-glow);
    }

    .child-avatar {
        width: 48px;
        height: 48px;
        border-radius: var(--vb-radius-full);
        background: var(--vb-gray-100);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
        color: var(--vb-text-secondary);
    }

    .child-info {
        flex: 1;
        min-width: 0;
    }

    .child-name {
        font-weight: 600;
        font-size: 1rem;
        color: var(--vb-text-primary);
    }

    .child-email {
        font-size: 0.85rem;
        color: var(--vb-text-secondary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-top: 2px;
    }

    .child-arrow {
        flex-shrink: 0;
        color: var(--vb-text-muted);
    }

    /* Modal */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        padding: 1rem;
    }

    .modal-content {
        background: var(--vb-bg-elevated);
        border: 1px solid var(--vb-card-border);
        border-radius: var(--vb-radius-md);
        box-shadow: var(--vb-shadow);
        width: 100%;
        max-width: 440px;
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--vb-divider);
    }

    .modal-header h3 {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--vb-text-primary);
    }

    .modal-close {
        background: none;
        border: none;
        font-size: 1.5rem;
        color: var(--vb-text-muted);
        cursor: pointer;
        line-height: 1;
    }

    .modal-close:hover {
        color: var(--vb-text-primary);
    }

    .modal-body {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        padding: 1rem 1.25rem;
        border-top: 1px solid var(--vb-divider);
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .form-group label {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--vb-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .form-input {
        padding: 0.6rem 0.75rem;
        border: 1px solid var(--vb-card-border);
        border-radius: var(--vb-radius-sm);
        background: var(--vb-bg);
        color: var(--vb-text-primary);
        font-size: 0.95rem;
        transition: var(--vb-transition);
    }

    .form-input:focus {
        outline: none;
        border-color: var(--vb-red);
        box-shadow: 0 0 0 2px var(--vb-red-glow);
    }

    .form-error {
        background: #fdf0f0;
        color: var(--vb-red);
        padding: 0.6rem 0.75rem;
        border-radius: var(--vb-radius-sm);
        font-size: 0.85rem;
        font-weight: 500;
    }
</style>

@code {
    private List<UserResponse> _children = new();
    private bool _loading = true;
    private bool _showAddModal;
    private bool _creating;
    private string _firstName = "";
    private string _lastName = "";
    private string _email = "";
    private string _password = "";
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var session = Auth.CurrentSession;
        if (session == null) { Navigation.NavigateTo("/login"); return; }
        if (session.Role != "Client") { Navigation.NavigateTo("/prehled"); return; }

        await LoadChildren();
    }

    private async Task LoadChildren()
    {
        _loading = true;
        try
        {
            var session = Auth.CurrentSession!;
            _children = await Api.GetChildrenAsync(session.UserId);
        }
        catch
        {
            _children = new();
        }
        _loading = false;
    }

    private void OpenAddModal()
    {
        _firstName = "";
        _lastName = "";
        _email = "";
        _password = "";
        _error = null;
        _showAddModal = true;
    }

    private void CloseAddModal()
    {
        _showAddModal = false;
        _error = null;
    }

    private async Task CreateChild()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_firstName) || string.IsNullOrWhiteSpace(_lastName)
            || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Vyplnte vsechna pole.";
            return;
        }

        _creating = true;
        try
        {
            var session = Auth.CurrentSession!;
            var child = await Api.CreateChildAsync(session.UserId, _firstName.Trim(), _lastName.Trim(), _email.Trim(), _password);

            // Auto-provision account for child
            await Api.CreateAccountAsync(child.Id, "CZK");

            // Auto-create family chat
            var childLabel = $"{child.FirstName} {child.LastName}";
            await Api.GetOrCreateFamilyChatAsync(session.UserId, child.Id, childLabel);

            _showAddModal = false;
            await LoadChildren();
        }
        catch (Exception ex)
        {
            _error = ex.Message.Contains("already exists")
                ? "Uzivatel s timto e-mailem jiz existuje."
                : $"Chyba pri vytvareni: {ex.Message}";
        }
        finally
        {
            _creating = false;
        }
    }

    private void GoToChild(Guid childId) => Navigation.NavigateTo($"/deti/{childId}");
}
