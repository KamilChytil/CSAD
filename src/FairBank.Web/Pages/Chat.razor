@page "/zpravy/{ConversationId:guid}"
@using FairBank.Web.Shared.Models.Chat
@using FairBank.Web.Shared.Services.Chat
@using FairBank.Web.Shared.Services
@inject ChatService ChatService
@inject IAuthService AuthService
@inject NavigationManager Navigation
@implements IDisposable

<div class="chat-container">
    <div class="chat-header">
        <button class="chat-back" @onclick="GoBack">←</button>
        <h3>@_label</h3>
    </div>
    
    <div class="chat-messages" id="message-list">
        @foreach (var msg in _messages)
        {
            var isMine = msg.SenderId == _currentUserId;
            <div class="message @(isMine ? "sent" : "received")">
                @if (!isMine)
                {
                    <div class="message-sender">@msg.SenderName</div>
                }
                <div class="message-content">@msg.Content</div>
                <div class="message-time">@msg.SentAt.ToShortTimeString()</div>
            </div>
        }
    </div>

    <div class="chat-input">
        <input type="text" @bind="_messageText" @onkeyup="HandleKeyUp" placeholder="Napište zprávu..." />
        <button @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(_messageText))">Odeslat</button>
    </div>
</div>

<style>
    .chat-container { display:flex; flex-direction:column; height:calc(100vh - 100px); max-width:800px; margin:0 auto; background:white; border-radius:8px; box-shadow:0 2px 10px rgba(0,0,0,.1); }
    .chat-header { display:flex; align-items:center; gap:.75rem; padding:1rem; border-bottom:1px solid #eee; background:#f8f9fa; border-radius:8px 8px 0 0; }
    .chat-back { background:none; border:none; font-size:1.2rem; cursor:pointer; padding:.25rem .5rem; border-radius:4px; }
    .chat-back:hover { background:#e9ecef; }
    .chat-messages { flex:1; overflow-y:auto; padding:1rem; display:flex; flex-direction:column; gap:.5rem; }
    .message { max-width:70%; padding:.5rem 1rem; border-radius:1rem; font-size:.9rem; }
    .message.sent { align-self:flex-end; background:#007bff; color:white; border-bottom-right-radius:.2rem; }
    .message.received { align-self:flex-start; background:#e9ecef; color:#333; border-bottom-left-radius:.2rem; }
    .message-sender { font-size:.75rem; font-weight:600; opacity:.7; margin-bottom:.2rem; }
    .message-time { font-size:.7rem; opacity:.7; margin-top:.2rem; text-align:right; }
    .chat-input { padding:1rem; border-top:1px solid #eee; display:flex; gap:.5rem; }
    .chat-input input { flex:1; padding:.5rem; border:1px solid #ddd; border-radius:4px; outline:none; }
    .chat-input button { padding:.5rem 1rem; background:#007bff; color:white; border:none; border-radius:4px; cursor:pointer; }
    .chat-input button:disabled { background:#ccc; }
</style>

@code {
    [Parameter] public Guid ConversationId { get; set; }

    private List<ChatMessageDto> _messages = new();
    private string _messageText = "";
    private Guid _currentUserId;
    private string _senderName = "";
    private string _label = "Chat";

    protected override async Task OnInitializedAsync()
    {
        var session = AuthService.CurrentSession;
        if (session == null) { await Task.Delay(100); session = AuthService.CurrentSession; }
        if (session == null) { Navigation.NavigateTo("/login"); return; }

        _currentUserId = session.UserId;
        _senderName = $"{session.FirstName} {session.LastName}";

        await ChatService.InitializeAsync(session.Token);
        await ChatService.JoinConversationAsync(ConversationId);

        _messages = (await ChatService.GetConversationMessagesAsync(ConversationId)).ToList();
        ChatService.OnMessageReceived += HandleMessageReceived;
    }

    private void HandleMessageReceived(ChatMessageDto message)
    {
        if (message.ConversationId != ConversationId) return;
        // Avoid echo for messages we already added optimistically
        if (_messages.Any(m => m.Id == message.Id)) return;
        _messages.Add(message);
        InvokeAsync(StateHasChanged);
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_messageText)) return;
        var text = _messageText;
        _messageText = "";
        await ChatService.SendMessageAsync(ConversationId, _currentUserId, _senderName, text);
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    private void GoBack() => Navigation.NavigateTo("/zpravy");

    public void Dispose()
    {
        ChatService.OnMessageReceived -= HandleMessageReceived;
        _ = ChatService.LeaveConversationAsync(ConversationId);
    }
}
