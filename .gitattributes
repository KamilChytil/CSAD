# Auto-detect text files and normalize line endings to LF on checkout
* text=auto eol=lf

# Force LF for shell scripts (must run on Linux containers)
*.sh text eol=lf

# Force LF for Dockerfiles
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Windows-only files can keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
